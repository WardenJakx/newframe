{
  "name": "frame",
  "version": "0.6.11",
  "description": "System-wide web3",
  "main": "compiled/main",
  "scripts": {
    "clean": "rimraf dist bundle compiled .parcel-cache node_modules",
    "setup:clean": "bun run clean && bun run setup",
    "setup": "bun install && bun run rebuild:natives && husky",
    "start": "bun run launch",
    "bundle": "bun run bundle:bridge && bun run bundle:tray && bun run bundle:dash && bun run bundle:dapp && bun run bundle:onboard && bun run bundle:notify && bun run bundle:dapp:inject",
    "bundle:bridge": "bun run parcel:build -- --target bridge resources/bridge/index.js",
    "bundle:tray": "bun run parcel:build -- --target tray app/tray/index.html",
    "bundle:dash": "bun run parcel:build -- --target dash app/dash/index.html",
    "bundle:dapp": "bun run parcel:build -- --target dapp app/dapp/index.html",
    "bundle:onboard": "bun run parcel:build -- --target onboard app/onboard/index.html",
    "bundle:notify": "bun run parcel:build -- --target notify app/notify/index.html",
    "bundle:dapp:inject": "bun run parcel:build -- --target inject main/dapps/server/inject/index.js",
    "serve": "bun run bundle:bridge && bun run dev:server & wait-on http://localhost:1234/tray/index.dev.html && bun run compile:watch",
    "dev": "node ./scripts/run-dev.mjs",
    "dev:server": "node ./scripts/bundler.mjs",
    "inspect": "bun run bundle && bun run launch:inspect",
    "launch": "cross-env NODE_ENV=production electron ./compiled/main",
    "launch:dev": "cross-env NODE_ENV=development ELECTRON_DISABLE_SECURITY_WARNINGS=true electron ./compiled/main --inspect",
    "launch:dev:traffic": "cross-env NODE_ENV=development LOG_TRAFFIC=true ELECTRON_DISABLE_SECURITY_WARNINGS=true electron ./compiled/main --inspect",
    "launch:dev:fullheight": "cross-env NODE_ENV=development FULL_HEIGHT=true ELECTRON_DISABLE_SECURITY_WARNINGS=true electron ./compiled/main --inspect",
    "launch:dev:worker": "cross-env NODE_ENV=development LOG_WORKER=true electron ./compiled/main",
    "launch:inspect": "cross-env NODE_ENV=production electron --inspect ./compiled/main",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "tsgo --project tsconfig.build.json --noEmit",
    "knip": "knip",
    "format": "prettier --write '**/*.{yml,json,md,html,ts,js}'",
    "format:check": "prettier --check '**/*.{yml,json,md,html,ts,js}'",
    "prod": "bun run compile && bun run bundle && bun run launch",
    "compile": "bun run copy-assets && tsgo --project tsconfig.build.json",
    "compile:watch": "bun run copy-assets && tsgo --project tsconfig.build.json -w",
    "build": "bun run compile && sleep 4 && bun run bundle && sleep 4 && electron-builder --config=build/electron-builder-standard.js",
    "copy-assets": "shx mkdir -p ./compiled/main/windows && shx cp ./main/windows/*.png ./compiled/main/windows",
    "parcel:build": "parcel build --no-autoinstall --public-url .",
    "publish": "electron-builder -c.snap.publish=github --config=build/electron-builder-standard.js",
    "publish:linux:arm64": "electron-builder -c.snap.publish=github --config=build/electron-builder-linux-arm64.js",
    "release": "bun run compile && sleep 4 && bun run bundle && sleep 4 && bun run publish",
    "rebuild:natives": "electron-builder install-app-deps",
    "test": "bun run test:unit && bun run test:e2e",
    "test:exec": "jest --detectOpenHandles --runInBand",
    "test:unit": "bun run test:unit:main && bun run test:unit:components && bun run test:unit:resources",
    "test:unit:main": "bun run test:exec -- --env=node ./test/main",
    "test:unit:resources": "bun run test:exec -- --env=node --roots=test/resources --testPathIgnorePatterns=\\(/Components/ /Hooks/\\)",
    "test:unit:components": "bun run test:exec -- --env=jsdom --roots test/app test/resources/Hooks test/resources/Components --testTimeout=500",
    "test:e2e": "bun run test:exec -- --env=node --config ./jest.e2e.config.json ./test/e2e",
    "test:usbAdapters": "ELECTRON_RUN_AS_NODE=true ./node_modules/.bin/electron ./node_modules/jest/bin/jest.js ./test/main/signers/ledger/adapter.test.js --testPathIgnorePatterns=''"
  },
  "author": {
    "name": "NewFrame Labs",
    "email": "My@my.came",
    "url": "https://frame.new"
  },
  "license": "GPL-3.0",
  "dependencies": {
    "@ethereumjs/common": "^10.1.2",
    "@ethereumjs/rlp": "^10.1.2",
    "@ethereumjs/tx": "^10.1.2",
    "@ethereumjs/util": "^10.1.2",
    "@ethereumjs/wallet": "^10.0.0",
    "@framelabs/pylon-client": "0.0.10",
    "@ledgerhq/hw-app-eth": "^7.8.5",
    "@ledgerhq/hw-transport-node-hid-noevents": "6.35.3",
    "@ledgerhq/hw-transport-node-hid-singleton": "6.35.3",
    "@metamask/eth-sig-util": "^8.2.0",
    "@scure/bip32": "^2.2.0",
    "@sentry/electron": "7.13.0",
    "@trezor/connect": "^9.7.3",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-common": "^3.0.4",
    "@zxcvbn-ts/language-en": "^3.0.2",
    "bip39": "3.1.0",
    "conf": "^15.1.0",
    "cookie": "^1.1.1",
    "electron-log": "^5.4.4",
    "electron-updater": "6.8.9",
    "eth-provider": "^0.13.7",
    "ethereum-provider": "0.7.7",
    "ethers": "6.16.0",
    "fs-extra": "^11.3.5",
    "get-pixels": "3.3.3",
    "gridplus-sdk": "^4.0.0",
    "hotkeys-js": "^4.0.4",
    "ipfs-http-client": "56.0.0",
    "ipfs-unixfs-importer": "9.0.9",
    "isutf8": "^4.0.1",
    "nebula": "0.1.5",
    "node-hid": "2.1.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-restore": "workspace:*",
    "semver": "7",
    "styled-components": "^6.4.2",
    "tar-fs": "^3.1.2",
    "uuid": "^14.0.0",
    "ws": "8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/preset-env": "7.29.7",
    "@babel/preset-react": "7.29.7",
    "@babel/preset-typescript": "7.29.7",
    "@electron/notarize": "3.1.1",
    "@eslint/js": "10.0.1",
    "@jest/globals": "^30.4.1",
    "@ledgerhq/hw-transport": "6.35.3",
    "@ledgerhq/hw-transport-mocker": "6.34.3",
    "@ledgerhq/types-live": "6.56.0",
    "@parcel/config-default": "2.16.4",
    "@parcel/core": "2.16.4",
    "@parcel/transformer-js": "2.16.4",
    "@parcel/transformer-react-refresh-wrap": "2.16.4",
    "@parcel/transformer-stylus": "2.16.4",
    "@parcel/transformer-typescript-tsc": "2.16.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/get-pixels": "^3.3.4",
    "@types/jest": "^30.0.0",
    "@types/node": "24",
    "@types/node-hid": "1.3.1",
    "@types/semver": "^7.7.1",
    "@types/tar-fs": "^2.0.4",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "7.0.0-dev.20260609.1",
    "cross-env": "^10.1.0",
    "electron": "42.4.0",
    "electron-builder": "26.15.2",
    "buffer": "^6.0.3",
    "electron-devtools-installer": "4.0.0",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-testing-library": "7.16.2",
    "events": "^3.3.0",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "knip": "6.16.1",
    "lint-staged": "17.0.7",
    "multiformats": "9.9.0",
    "nock": "^14.0.15",
    "node-gyp": "^12.3.0",
    "parcel": "2.16.4",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "shx": "^0.4.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "wait-on": "^9.0.10"
  },
  "alias": {
    "uuid": "./node_modules/uuid/dist/index.js",
    "buffer": "buffer",
    "crypto": false,
    "path": false,
    "process": false,
    "punycode": false,
    "querystring": false,
    "stream": false,
    "string_decoder": false,
    "url": false,
    "http": false,
    "https": false,
    "zlib": false
  },
  "engines": {
    "electron": "42",
    "node": ">= 22.12.0"
  },
  "browserslist": [
    "last 1 Electron major version"
  ],
  "bridge": "./bundle/bridge.js",
  "inject": "./bundle/inject.js",
  "tray": "./bundle/tray.html",
  "dash": "./bundle/dash.html",
  "dapp": "./bundle/dapp.html",
  "onboard": "./bundle/onboard.html",
  "notify": "./bundle/notify.html",
  "targets": {
    "main": false,
    "bridge": {
      "context": "electron-renderer",
      "isLibrary": true,
      "sourceMap": {
        "inline": true
      }
    },
    "dash": {
      "context": "browser"
    },
    "dapp": {
      "context": "browser"
    },
    "onboard": {
      "context": "browser"
    },
    "notify": {
      "context": "browser"
    },
    "inject": {
      "context": "browser"
    },
    "tray": {
      "context": "browser"
    },
    "default": {
      "distDir": "./bundle"
    }
  },
  "repository": "github:floating/frame",
  "trustedDependencies": [
    "core-js",
    "electron",
    "keccak",
    "lmdb",
    "node-hid",
    "secp256k1"
  ],
  "overrides": {
    "@framelabs/logger": "1.1.1",
    "node-gyp": "12.3.0",
    "@ledgerhq/hw-transport": "6.35.3",
    "@ledgerhq/devices": "8.15.0",
    "@ledgerhq/logs": "6.17.0",
    "usb": "2.18.0"
  }
}
