{
  "name": "newframe-extension",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "git://github.com/wardenjakx/newframe.git",
    "directory": "apps/newframe-extension"
  },
  "description": "Newframe Companion Extension",
  "main": "src",
  "scripts": {
    "test": "bun run lint",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write '**/*.{yml,json,md,html,ts,tsx,js}'",
    "build": "bun run build.ts",
    "bundle": "bun run build.ts",
    "watch": "bun run build.ts --watch",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "author": "NewFrame Labs, Inc.",
  "license": "",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bun": "latest",
    "@types/chrome": "^0.1.43",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript/native-preview": "^7.0.0-dev.20260610.1",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "8.61.0"
  },
  "dependencies": {
    "events": "3.3.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-restore": "workspace:*",
    "styled-components": "^6.4.2"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
