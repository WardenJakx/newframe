{
  "name": "newframe-extension",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "git://github.com/wardenjakx/newframe.git",
    "directory": "apps/newframe-extension"
  },
  "description": "Newframe Companion Extension",
  "main": "src",
  "scripts": {
    "test": "bun test && bun run lint",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write '**/*.{yml,json,md,html,ts,tsx,js,mjs}' --config ../../.prettierrc.json --ignore-path ../../.prettierignore",
    "build": "bun run build.ts",
    "bundle": "bun run build.ts",
    "watch": "bun run build.ts --watch",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "author": "NewFrame Labs, Inc.",
  "license": "",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/chrome": "^0.1.43",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript/native-preview": "^7.0.0-dev.20260610.1"
  },
  "dependencies": {
    "@newframe/ui": "workspace:*",
    "events": "3.3.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zustand": "^5.0.14"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
