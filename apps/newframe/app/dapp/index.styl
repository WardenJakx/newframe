@keyframes load
  0%
    transform rotate(0deg)
  100%
    transform rotate(360deg)

body
  width 100%
  height 100%
  margin 0
  padding 0px
  font-family 'MainFont'
  font-weight 300

  #dapp
    width 100%
    height 100%
    padding 0px
    position relative

    .overlay
      position absolute
      top 0 
      right 0
      bottom 0 
      left 0
      background linear-gradient(-35deg, var(--overlayA) 0%, var(--overlayB) 100%)
      z-index 999
      pointer-events none

    .backdrop
      position absolute
      top 0px
      left 0px
      right 0px
      bottom 0px
      z-index 0
      border-radius 6px
      box-shadow cardDrop, 0px 0px 2px outerspace03
      pointer-events none

    .splash
      position absolute
      top 0px
      left 0px
      right 0px
      bottom 0px
      z-index 0

    .mainLeft
      position absolute
      top 0
      left 0
      bottom 0
      width 72px
      padding-left 2px
      -webkit-user-select none
      display none

      .accountTile
        position absolute
        top 26px
        left 5px
        right 5px
        display flex
        justify-content center
        align-items center
        flex-direction column
        color var(--outerspace)
        margin 6px 0px

        .accountIcon
          height 58px
          width 58px
          background var(--ghostA)
          border-radius 16px
          display flex
          justify-content center
          align-items center
          flex-direction column
          cursor pointer

        .accountIcon:hover
          background var(--ghostB)

      .dappIcons
        position absolute
        top 72px
        bottom 72px
        left 0px
        right 0px
        display flex
        justify-content center
        align-items center

        .dappIconsScroll
          max-height 100%
          width 100%
          overflow-y scroll
          overflow-x hidden
          -webkit-user-select auto

          .dappIconsWrap
            padding-top 10px

    .main
      position absolute
      top 0
      left 0px
      bottom 0
      right 0
      // border-left 1px solid var(--ghostX)
      color var(--outerspace)
      display flex
      justify-content center
      align-items center
      -webkit-user-select none
      // overflow-y scroll
      z-index 9999
      
      .mainDappBackground
        position absolute
        top 0
        left 0
        bottom 0
        right 0
        -webkit-user-select none
        z-index 1
        display flex
        justify-content center
        align-items center

      .mainDappLoading
        .mainDappLoadingText
          font-family 'MainFont'
          text-transform uppercase
          font-size 14px
          font-weight 400
          text-align center
          line-height 20px
          letter-spacing 1px

        .loader,
        .loader:after
          border-radius 100%
          width 128px
          height 128px

        .loader
          font-size 7px
          position relative
          text-indent -9999em
          transform translateZ(0)
          animation load8 0.48s infinite linear !important
          border-top 3px solid var(--ghostY)
          border-right 3px solid var(--ghostY)
          border-bottom 3px solid var(--ghostY)
          border-left 3px solid var(--ghostD)
          will-change transform

        @keyframes load8
          0%
            transform rotate(0deg)
          100%
            transform rotate(360deg)

      .mainDappEnableChains
        height 40px
        margin-top 30px
        background var(--ghostC)
        border-bottom 2px solid var(--ghostZ)
        box-shadow 0px 1px 4px var(--ghostX)
        border-radius 15px
        box-sizing border-box
        cursor pointer
        display flex
        justify-content center
        align-items center
        font-size 14px
        font-weight 400
        letter-spacing 1px
        text-transform uppercase
        padding 1px 20px 0px 21px

      .mainDappEnableChains:hover
        background var(--ghostD)
        color var(--outerspace)

      .mainApps
        width 600px
        height 300px
        border-radius 16px
        // border 1px solid var(--ghostY)
        background var(--ghostY)

    .top
      position absolute
      top 0px
      left 0px
      right 0px
      height 37px
      z-index 50
      
      .break
        position absolute
        height 1px
        bottom 0px
        left 0
        right 0
        opacity 0.2
        background white
      
      .title
        position absolute
        top 0
        right 0
        left 0
        bottom 0
        z-index 1
        display flex
        justify-content center
        align-items center
        font-size 12px
        font-weight 300
        letter-spacing 1px
        pointer-events none
        user-select none
        font-family -apple-system, BlinkMacSystemFont, "Segoe UI", Ubuntu, Cantarell, "Oxygen Sans", "Helvetica Neue", sans-serif

      .menu
        position absolute
        top 0
        right 0px
        bottom 0
        width 85px
        z-index 3
        // background red

        .reload
          height 37px
          width 34px
          padding-top 1px
          position absolute
          top 0
          right 0
          bottom 0
          box-sizing border-box
          display flex
          justify-content center
          align-items center

        .reload:hover
          // color outerspace05
          // background green

    .shade
      position absolute
      top 37px
      left 0px
      right 0px
      bottom 0px
      transition var(--standard)
      z-index 150
      border-radius 6px
      // border-bottom-left-radius 4px
      // border-bottom-right-radius 4px
      // border-bottom-left-radius 4px
      // border-bottom-right-radius 4px
      border-bottom 2px solid outerspace05
      // border-top 2px solid thick
      box-shadow reverseCardDrop // , 0px 0px 4px rgba(10, 10, 40, 0.2)
      pointer-events none

    .webloading
      display none
      position absolute
      top 37px
      left 0px
      right 0px
      bottom 0px
      z-index 100
      transition var(--standard)
      border-radius 6px
      background linear-gradient(180deg, highlight 0%, thick 100%)
      display flex
      justify-content center
      align-items center
      // box-shadow reverseCardDrop, 0px 0px 4px rgba(25, 25, 50, 0.2)

      img
        position absolute
        max-height 40px
        max-width 40px

    .webwrap
      position absolute
      top 37px
      left 0px
      right 0px
      bottom 0px
      z-index 1000
      transition var(--standard)
      border-radius 6px

      .view
        position absolute
        top 0
        left 0
        right 0
        bottom 0
        border-radius 6px
        overflow hidden
        z-index 100

      view
        height 100%
        width 100%
        // border-radius 6px

// ==================== local send app ====================

$send-bg = rgba(18, 14, 20, 1)
$send-pill = rgba(26, 22, 28, 1)
$send-pill-hover = rgba(32, 28, 36, 1)
$send-card = rgba(24, 20, 27, 1)
$send-card-hover = rgba(30, 26, 34, 1)
$send-button = rgba(29, 25, 33, 1)
$send-button-hover = rgba(35, 31, 40, 1)
$send-menu = rgba(31, 27, 35, 1)
$send-menu-hover = rgba(40, 36, 45, 1)
$send-text = rgba(248, 255, 255, 1)
$send-muted = rgba(223, 223, 237, 0.45)
$send-muted-strong = rgba(223, 223, 237, 0.7)
$send-divider = rgba(248, 255, 255, 0.06)
$send-teal = rgb(0, 210, 190)
$send-teal-bright = rgb(40, 225, 205)
$send-warning = rgb(241, 201, 80)
$send-danger = rgb(255, 110, 120)

body
  background $send-bg

.sendApp
  position absolute
  top 0
  right 0
  bottom 0
  left 0
  background $send-bg
  color $send-text
  font-family 'MainFont'
  overflow hidden
  display flex
  flex-direction column
  -webkit-user-select none

  *
    box-sizing border-box
    letter-spacing 0

.sendHeader
  height 64px
  flex-shrink 0
  display flex
  align-items center
  justify-content space-between
  padding 14px 16px 8px 16px

.sendBackButton,
.sendHeaderSpacer
  width 36px
  height 36px

.sendBackButton
  border none
  outline none
  background transparent
  color $send-muted-strong
  display flex
  align-items center
  justify-content center
  padding 0
  cursor pointer
  border-radius 18px

  &:hover
    background $send-button-hover
    color $send-teal

  *
    pointer-events none

.sendTitle
  font-size 20px
  font-weight 600
  color $send-text

.sendBody
  position relative
  flex-grow 1
  overflow-y auto
  overflow-x hidden
  padding 0 12px 116px 12px

.sendCard
  position relative
  background $send-card
  border-radius 14px
  padding 14px
  margin-bottom 10px

.sendRecipientCard
  z-index 4

.sendRecipientCardSelected
  padding 14px 12px 13px 12px

.sendSectionTitle
  color $send-muted-strong
  font-size 15px
  font-weight 500
  margin-bottom 12px

.sendInputRow
  height 48px
  border-radius 13px
  background $send-pill
  display flex
  align-items center
  padding 0 6px 0 12px

  input
    flex-grow 1
    min-width 0
    border none
    outline none
    color $send-text
    background transparent
    font-family 'MainFont'
    font-size 15px
    padding 0

    &::placeholder
      color $send-muted-strong

.sendInputToggle
  width 34px
  height 34px
  border none
  background transparent
  color $send-muted-strong
  display flex
  align-items center
  justify-content center
  padding 0
  cursor pointer

  *
    pointer-events none

.sendRecipientMenu
  margin-top 10px
  max-height 190px
  background $send-menu
  border-radius 14px
  overflow-y auto
  box-shadow 0 16px 32px rgba(0, 0, 0, 0.28)

.sendRecipientMenuTitle
  height 42px
  padding 0 13px
  display flex
  align-items center
  gap 8px
  color $send-muted-strong
  font-size 14px
  border-bottom 1px solid $send-divider

.sendWalletRow
  width 100%
  min-height 56px
  border none
  outline none
  background $send-menu
  color $send-text
  display flex
  align-items center
  gap 10px
  padding 9px 12px
  text-align left
  cursor pointer

  &:hover
    background $send-menu-hover

.sendAccountIcon
  width 34px
  height 34px
  border-radius 50%
  flex-shrink 0
  display flex
  align-items center
  justify-content center
  background $send-button
  color $send-teal

  *
    pointer-events none

.sendWalletInfo,
.sendRecipientText
  min-width 0
  flex-grow 1

.sendWalletName,
.sendRecipientName
  color $send-text
  font-size 16px
  font-weight 600
  overflow hidden
  text-overflow ellipsis
  white-space nowrap

.sendWalletAddress,
.sendRecipientAddress
  color $send-muted-strong
  font-family 'FiraCode'
  font-size 11px
  overflow hidden
  text-overflow ellipsis
  white-space nowrap
  margin-top 2px

.sendWalletCopy,
.sendRecipientCopy
  color $send-muted-strong
  display flex
  flex-shrink 0

.sendRecipientPill
  min-height 58px
  border 1px solid $send-teal
  border-radius 15px
  display flex
  align-items center
  gap 10px
  padding 8px 10px
  background $send-pill

.sendRecipientClear
  width 30px
  height 30px
  border none
  outline none
  background transparent
  color $send-muted-strong
  padding 0
  cursor pointer
  display flex
  align-items center
  justify-content center

  *
    pointer-events none

.sendRecipientNotice
  color $send-warning
  font-size 13px
  margin 10px 0 0 8px

.sendTokenCard
  z-index 5
  padding 16px 14px 18px 14px

.sendTokenMain
  display flex
  align-items center
  justify-content space-between
  gap 12px

.sendTokenPicker
  position relative
  flex-shrink 0

.sendTokenButton
  width 204px
  min-height 50px
  border none
  outline none
  border-radius 15px
  background $send-pill
  color $send-text
  display flex
  align-items center
  gap 9px
  padding 8px 12px
  cursor pointer

  &:hover
    background $send-pill-hover

.sendTokenIcon
  position relative
  width 38px
  height 38px
  flex-shrink 0

.sendTokenIconInner
  width 38px
  height 38px
  border-radius 50%
  background $send-button
  border 1px solid rgba(248, 255, 255, 0.1)
  display flex
  align-items center
  justify-content center
  color rgba(248, 255, 255, 0.85)
  overflow hidden

  img
    width 100%
    height 100%
    object-fit cover

.sendTokenIconGlyph
  font-family 'FiraCode'
  font-size 15px
  font-weight 500

.sendTokenChainBadge
  position absolute
  top -7px
  left -7px
  width 22px
  height 22px
  border-radius 50%
  border 2px solid $send-bg
  background $send-button
  box-sizing border-box
  display flex
  align-items center
  justify-content center
  overflow hidden

  img
    border-radius 50%
    object-fit cover

.sendChainIconDot
  border-radius 50%

.sendTokenText
  min-width 0
  flex-grow 1
  text-align left

.sendTokenSymbol
  font-size 16px
  font-weight 700
  line-height 18px
  overflow hidden
  text-overflow ellipsis
  white-space nowrap

.sendTokenChain
  margin-top 2px
  font-size 12px
  color $send-muted-strong
  overflow hidden
  text-overflow ellipsis
  white-space nowrap

.sendTokenChevron
  color $send-muted-strong
  display flex
  transform rotate(180deg)
  flex-shrink 0

.sendTokenMenu
  position absolute
  left 0
  top 56px
  width 260px
  max-height 220px
  overflow-y auto
  border-radius 14px
  background $send-menu
  box-shadow 0 16px 32px rgba(0, 0, 0, 0.32)
  z-index 10
  padding 6px

.sendTokenOption
  width 100%
  border none
  outline none
  color $send-text
  background transparent
  border-radius 11px
  min-height 48px
  display flex
  align-items center
  gap 9px
  padding 7px
  cursor pointer

  &:hover
    background $send-menu-hover

.sendTokenOptionBalance
  color $send-muted-strong
  font-family 'FiraCode'
  font-size 12px
  flex-shrink 0
  max-width 72px
  overflow hidden
  text-overflow ellipsis
  white-space nowrap

.sendTokenMore
  width 100%
  border none
  outline none
  color $send-muted-strong
  background transparent
  border-radius 11px
  min-height 38px
  padding 8px
  cursor pointer
  font-size 12px
  font-weight 600

  &:hover
    background $send-menu-hover
    color $send-text

.sendAmountInput
  min-width 70px
  flex-grow 1
  border none
  outline none
  background transparent
  color $send-text
  font-family 'FiraCode'
  font-size 28px
  text-align right
  padding 2px 8px

.sendTokenMeta
  height 28px
  margin-top 12px
  display flex
  align-items center
  justify-content space-between

.sendBalance
  display flex
  align-items center
  gap 7px
  min-width 0
  color $send-muted-strong
  font-size 13px

  span
    min-width 0
    overflow hidden
    text-overflow ellipsis
    white-space nowrap

  button
    height 24px
    border none
    outline none
    border-radius 12px
    background rgba(0, 210, 190, 0.12)
    color $send-teal
    padding 0 10px
    cursor pointer

    &:hover
      background rgba(0, 210, 190, 0.18)
      color $send-teal-bright

.sendFiatValue
  color $send-muted-strong
  font-family 'FiraCode'
  font-size 13px
  flex-shrink 0

.sendMessage
  text-align center
  color $send-muted-strong
  font-size 13px
  padding 5px 12px

.sendMessageError
  color $send-danger

.sendEmpty
  flex-grow 1
  display flex
  align-items center
  justify-content center
  color $send-muted-strong
  font-size 14px

.sendFooter
  position absolute
  left 50%
  bottom 12px
  width 156px
  height 64px
  transform translateX(-50%)
  border-radius 32px
  background $send-pill
  border 1px solid $send-divider
  box-shadow 0 12px 28px rgba(0, 0, 0, 0.28)
  display flex
  align-items center
  justify-content center
  padding 8px
  z-index 20

.sendProceedButton
  height 48px
  border none
  outline none
  border-radius 24px
  display flex
  align-items center
  justify-content center
  font-size 15px
  font-weight 700

.sendProceedButton
  width 140px
  cursor pointer
  background $send-teal
  color rgb(8, 16, 18)

  &:hover
    background $send-teal-bright

.sendProceedButtonDisabled
  cursor default
  opacity 0.42

@media (max-width: 390px)
  .sendFooter
    width 156px

  .sendProceedButton
    width 140px

  .sendTokenButton
    width 178px
