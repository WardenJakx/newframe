@keyframes load
  0%
    transform rotate(0deg)
  100%
    transform rotate(360deg)

body
  width 100%
  height 100%
  margin 0
  padding 0px
  font-family 'MainFont'
  font-weight 300

  #dapp
    width 100%
    height 100%
    padding 0px
    position relative

    .overlay
      position absolute
      top 0 
      right 0
      bottom 0 
      left 0
      background linear-gradient(-35deg, var(--color-overlay-start) 0%, var(--color-overlay-end) 100%)
      z-index 999
      pointer-events none

    .backdrop
      position absolute
      top 0px
      left 0px
      right 0px
      bottom 0px
      z-index 0
      border-radius 6px
      box-shadow 0px 1px 1px var(--color-shadow-subtle), 0px 0px 2px var(--color-text-disabled)
      pointer-events none

    .splash
      position absolute
      top 0px
      left 0px
      right 0px
      bottom 0px
      z-index 0

    .mainLeft
      position absolute
      top 0
      left 0
      bottom 0
      width 72px
      padding-left 2px
      -webkit-user-select none
      display none

      .accountTile
        position absolute
        top 26px
        left 5px
        right 5px
        display flex
        justify-content center
        align-items center
        flex-direction column
        color var(--color-text-primary)
        margin 6px 0px

        .accountIcon
          height 58px
          width 58px
          background var(--color-bg-raised)
          border-radius 16px
          display flex
          justify-content center
          align-items center
          flex-direction column
          cursor pointer

        .accountIcon:hover
          background var(--color-bg-control)

      .dappIcons
        position absolute
        top 72px
        bottom 72px
        left 0px
        right 0px
        display flex
        justify-content center
        align-items center

        .dappIconsScroll
          max-height 100%
          width 100%
          overflow-y scroll
          overflow-x hidden
          -webkit-user-select auto

          .dappIconsWrap
            padding-top 10px

    .main
      position absolute
      top 0
      left 0px
      bottom 0
      right 0
      // border-left 1px solid var(--color-border-default)
      color var(--color-text-primary)
      display flex
      justify-content center
      align-items center
      -webkit-user-select none
      // overflow-y scroll
      z-index 9999
      
      .mainDappBackground
        position absolute
        top 0
        left 0
        bottom 0
        right 0
        -webkit-user-select none
        z-index 1
        display flex
        justify-content center
        align-items center

      .mainDappLoading
        .mainDappLoadingText
          font-family 'MainFont'
          text-transform uppercase
          font-size 14px
          font-weight 400
          text-align center
          line-height 20px
          letter-spacing 1px

        .loader,
        .loader:after
          border-radius 100%
          width 128px
          height 128px

        .loader
          font-size 7px
          position relative
          text-indent -9999em
          transform translateZ(0)
          animation load8 0.48s infinite linear !important
          border-top 3px solid var(--color-bg-primary)
          border-right 3px solid var(--color-bg-primary)
          border-bottom 3px solid var(--color-bg-primary)
          border-left 3px solid var(--color-bg-hover)
          will-change transform

        @keyframes load8
          0%
            transform rotate(0deg)
          100%
            transform rotate(360deg)

      .mainDappEnableChains
        height 40px
        margin-top 30px
        background var(--color-bg-hover)
        border-bottom 2px solid var(--color-bg-primary)
        box-shadow 0px 1px 4px var(--color-shadow-default)
        border-radius 15px
        box-sizing border-box
        cursor pointer
        display flex
        justify-content center
        align-items center
        font-size 14px
        font-weight 400
        letter-spacing 1px
        text-transform uppercase
        padding 1px 20px 0px 21px

      .mainDappEnableChains:hover
        background var(--color-bg-hover)
        color var(--color-text-primary)

      .mainApps
        width 600px
        height 300px
        border-radius 16px
        // border 1px solid var(--color-bg-primary)
        background var(--color-bg-primary)

    .top
      position absolute
      top 0px
      left 0px
      right 0px
      height 37px
      z-index 50
      
      .break
        position absolute
        height 1px
        bottom 0px
        left 0
        right 0
        opacity 0.2
        background var(--color-border-strong)
      
      .title
        position absolute
        top 0
        right 0
        left 0
        bottom 0
        z-index 1
        display flex
        justify-content center
        align-items center
        font-size 12px
        font-weight 300
        letter-spacing 1px
        pointer-events none
        user-select none
        font-family -apple-system, BlinkMacSystemFont, "Segoe UI", Ubuntu, Cantarell, "Oxygen Sans", "Helvetica Neue", sans-serif

      .menu
        position absolute
        top 0
        right 0px
        bottom 0
        width 85px
        z-index 3
        // background red

        .reload
          height 37px
          width 34px
          padding-top 1px
          position absolute
          top 0
          right 0
          bottom 0
          box-sizing border-box
          display flex
          justify-content center
          align-items center

        .reload:hover
          // color outerspace05
          // background green

    .shade
      position absolute
      top 37px
      left 0px
      right 0px
      bottom 0px
      transition var(--standard)
      z-index 150
      border-radius 6px
      // border-bottom-left-radius 4px
      // border-bottom-right-radius 4px
      // border-bottom-left-radius 4px
      // border-bottom-right-radius 4px
      border-bottom 2px solid var(--color-border-subtle)
      box-shadow 0px -1px 1px var(--color-shadow-subtle)
      pointer-events none

    .webloading
      display none
      position absolute
      top 37px
      left 0px
      right 0px
      bottom 0px
      z-index 100
      transition var(--standard)
      border-radius 6px
      background linear-gradient(180deg, var(--color-bg-raised) 0%, var(--color-bg-primary) 100%)
      display flex
      justify-content center
      align-items center

      img
        position absolute
        max-height 40px
        max-width 40px

    .webwrap
      position absolute
      top 37px
      left 0px
      right 0px
      bottom 0px
      z-index 1000
      transition var(--standard)
      border-radius 6px

      .view
        position absolute
        top 0
        left 0
        right 0
        bottom 0
        border-radius 6px
        overflow hidden
        z-index 100

      view
        height 100%
        width 100%
        // border-radius 6px

// ==================== local send app ====================

body
  background var(--color-bg-primary)

.sendApp
  position absolute
  top 0
  right 0
  bottom 0
  left 0
  background var(--color-bg-primary)
  color var(--color-text-primary)
  font-family 'MainFont'
  overflow hidden
  display flex
  flex-direction column
  -webkit-user-select none

  *
    box-sizing border-box
    letter-spacing 0

.sendHeader
  height 64px
  flex-shrink 0
  display flex
  align-items center
  justify-content space-between
  padding 14px 16px 8px 16px

.sendBackButton,
.sendHeaderSpacer
  width 36px
  height 36px

.sendBackButton
  border none
  outline none
  background transparent
  color var(--color-text-secondary)
  display flex
  align-items center
  justify-content center
  padding 0
  cursor pointer
  border-radius 18px

  &:hover
    background var(--color-bg-hover)
    color var(--color-action-primary)

  *
    pointer-events none

.sendTitle
  font-size 20px
  font-weight 600
  color var(--color-text-primary)

.sendBody
  position relative
  flex-grow 1
  overflow-y auto
  overflow-x hidden
  padding 0 12px 116px 12px

.sendCard
  position relative
  background var(--color-bg-card)
  border-radius 14px
  padding 14px
  margin-bottom 10px

.sendRecipientCard
  z-index 4

.sendRecipientCardSelected
  padding 14px 12px 13px 12px

.sendSectionTitle
  color var(--color-text-secondary)
  font-size 15px
  font-weight 500
  margin-bottom 12px

.sendInputRow
  height 48px
  border-radius 13px
  background var(--color-bg-raised)
  display flex
  align-items center
  padding 0 6px 0 12px

  input
    flex-grow 1
    min-width 0
    border none
    outline none
    color var(--color-text-primary)
    background transparent
    font-family 'MainFont'
    font-size 15px
    padding 0

    &::placeholder
      color var(--color-text-secondary)

.sendInputToggle
  width 34px
  height 34px
  border none
  background transparent
  color var(--color-text-secondary)
  display flex
  align-items center
  justify-content center
  padding 0
  cursor pointer

  *
    pointer-events none

.sendRecipientMenu
  margin-top 10px
  max-height 190px
  background var(--color-bg-control)
  border-radius 14px
  overflow-y auto
  box-shadow 0 16px 32px var(--color-shadow-default)

.sendRecipientMenuTitle
  height 42px
  padding 0 13px
  display flex
  align-items center
  gap 8px
  color var(--color-text-secondary)
  font-size 14px
  border-bottom 1px solid var(--color-border-subtle)

.sendWalletRow
  width 100%
  min-height 56px
  border none
  outline none
  background var(--color-bg-control)
  color var(--color-text-primary)
  display flex
  align-items center
  gap 10px
  padding 9px 12px
  text-align left
  cursor pointer

  &:hover
    background var(--color-bg-hover)

.sendAccountIcon
  width 34px
  height 34px
  border-radius 50%
  flex-shrink 0
  display flex
  align-items center
  justify-content center
  background var(--color-bg-control)
  color var(--color-action-primary)

  *
    pointer-events none

.sendWalletInfo,
.sendRecipientText
  min-width 0
  flex-grow 1

.sendWalletName,
.sendRecipientName
  color var(--color-text-primary)
  font-size 16px
  font-weight 600
  overflow hidden
  text-overflow ellipsis
  white-space nowrap

.sendWalletAddress,
.sendRecipientAddress
  color var(--color-text-secondary)
  font-family 'FiraCode'
  font-size 11px
  overflow hidden
  text-overflow ellipsis
  white-space nowrap
  margin-top 2px

.sendWalletCopy,
.sendRecipientCopy
  color var(--color-text-secondary)
  display flex
  flex-shrink 0

.sendRecipientPill
  min-height 58px
  border 1px solid var(--color-action-primary)
  border-radius 15px
  display flex
  align-items center
  gap 10px
  padding 8px 10px
  background var(--color-bg-raised)

.sendRecipientClear
  width 30px
  height 30px
  border none
  outline none
  background transparent
  color var(--color-text-secondary)
  padding 0
  cursor pointer
  display flex
  align-items center
  justify-content center

  *
    pointer-events none

.sendRecipientNotice
  color var(--color-status-warning)
  font-size 13px
  margin 10px 0 0 8px

.sendTokenCard
  z-index 5
  padding 16px 14px 18px 14px

.sendTokenMain
  display flex
  align-items center
  justify-content space-between
  gap 12px

.tokenSelectorMore
  width 100%
  border none
  outline none
  color var(--color-text-secondary)
  background transparent
  border-radius 11px
  min-height 38px
  padding 8px
  cursor pointer
  font-size 12px
  font-weight 600

  &:hover
    background var(--color-bg-hover)
    color var(--color-text-primary)

.sendAmountInput
  min-width 70px
  flex-grow 1
  border none
  outline none
  background transparent
  color var(--color-text-primary)
  font-family 'FiraCode'
  font-size 28px
  text-align right
  padding 2px 8px

.sendTokenMeta
  height 28px
  margin-top 12px
  display flex
  align-items center
  justify-content space-between

.sendBalance
  display flex
  align-items center
  gap 7px
  min-width 0
  color var(--color-text-secondary)
  font-size 13px

  span
    min-width 0
    overflow hidden
    text-overflow ellipsis
    white-space nowrap

  button
    height 24px
    border none
    outline none
    border-radius 12px
    background var(--color-action-primary-subtle)
    color var(--color-action-primary)
    padding 0 10px
    cursor pointer

    &:hover
      background var(--color-action-primary-subtle)
      color var(--color-action-primary-hover)

.sendFiatValue
  color var(--color-text-secondary)
  font-family 'FiraCode'
  font-size 13px
  flex-shrink 0

.sendMessage
  text-align center
  color var(--color-text-secondary)
  font-size 13px
  padding 5px 12px

.sendMessageError
  color var(--color-status-danger)

.sendEmpty
  flex-grow 1
  display flex
  align-items center
  justify-content center
  color var(--color-text-secondary)
  font-size 14px

.sendFooter
  position absolute
  left 50%
  bottom 12px
  width 156px
  height 64px
  transform translateX(-50%)
  border-radius 32px
  background var(--color-bg-raised)
  border 1px solid var(--color-border-subtle)
  box-shadow 0 12px 28px var(--color-shadow-default)
  display flex
  align-items center
  justify-content center
  padding 8px
  z-index 20

.sendProceedButton
  height 48px
  border none
  outline none
  border-radius 24px
  display flex
  align-items center
  justify-content center
  font-size 15px
  font-weight 700

.sendProceedButton
  width 140px
  cursor pointer
  background var(--color-action-primary)
  color var(--color-action-primary-text)

  &:hover
    background var(--color-action-primary-hover)

.sendProceedButtonDisabled
  cursor default
  opacity 0.42

@media (max-width: 390px)
  .sendFooter
    width 156px

  .sendProceedButton
    width 140px

// ==================== local trade app ====================

.tradeApp
  position absolute
  top 0
  right 0
  bottom 0
  left 0
  background var(--color-bg-primary)
  color var(--color-text-primary)
  font-family 'MainFont'
  overflow hidden
  display flex
  flex-direction column
  -webkit-user-select none

  *
    box-sizing border-box
    letter-spacing 0

.tradeBody
  position relative
  flex-grow 1
  min-height 0
  overflow-y auto
  overflow-x hidden
  display flex
  flex-direction column
  padding 0 12px 100px 12px

.tradeTabsWrap
  margin 0 0 12px 0
  min-height 34px

.tradeTabs
  width fit-content
  height 34px
  display inline-flex
  align-items center
  gap 8px

.tradeTab
  border none
  outline none
  height 30px
  border-radius 999px
  background transparent
  color var(--color-text-secondary)
  cursor pointer
  font-size 13px
  font-weight 700
  display flex
  align-items center
  justify-content center
  padding 0 14px

  &:hover
    color var(--color-text-primary)
    background var(--color-border-subtle)

.tradeTabActive
  background var(--color-status-special-subtle)
  color var(--color-status-special)

  &:hover
    color var(--color-status-special)
    background var(--color-status-special-subtle)

.tradeLimitSelectRow
  margin-top 10px
  display flex
  justify-content flex-start
  width 100%

.tradeLimitSelect
  width 100%
  height 46px
  border 1px solid var(--color-border-subtle)
  outline none
  border-radius 8px
  background var(--color-bg-raised)
  color var(--color-text-primary)
  padding 0 14px
  font-family 'MainFont'
  font-size 15px
  font-weight 800

.tradeOrderFields
  display grid
  grid-template-columns 1fr
  gap 8px
  margin -2px 0 10px 0

.tradeOrderFieldsTwo
  grid-template-columns repeat(2, minmax(0, 1fr))

.tradeOrderField
  min-width 0
  height 48px
  border 1px solid var(--color-border-subtle)
  border-radius 8px
  background var(--color-border-subtle)
  display flex
  align-items center
  gap 8px
  padding 0 10px

  span
    color var(--color-text-secondary)
    font-size 12px
    font-weight 800
    white-space nowrap

  input
    min-width 0
    width 100%
    border none
    outline none
    background transparent
    color var(--color-text-primary)
    font-family 'FiraCode'
    font-size 14px
    text-align right

.tradeTicket
  position relative
  z-index 4

.tradeAssetCard
  position relative
  overflow visible
  background var(--color-bg-card)
  border 1px solid var(--color-border-subtle)
  border-radius 8px
  padding 12px
  margin-bottom 8px

.tradeAssetCardEditable
  border-color var(--color-action-primary-border)
  background var(--color-bg-raised)

.tradeAssetCardHeader
  min-height 30px
  display flex
  align-items center
  justify-content space-between
  gap 8px

.tradeIntentLine
  min-width 0
  display flex
  align-items center
  gap 7px
  color var(--color-text-primary)
  font-size 14px
  font-weight 800
  text-transform uppercase

  > span
    min-width 0
    overflow hidden
    text-overflow ellipsis
    white-space nowrap

.tradeIntentBuy
  color var(--color-status-special)

.tradeIntentSell
  color var(--color-status-danger)

.tradeDirectionSwitch
  width 24px
  height 24px
  border none
  outline none
  border-radius 6px
  background var(--color-border-subtle)
  color var(--color-text-secondary)
  cursor pointer
  flex-shrink 0
  display flex
  align-items center
  justify-content center
  padding 0

  &:hover
    color var(--color-action-primary-hover)
    background var(--color-action-primary-subtle)

  svg
    width 14px
    height 14px

  path
    fill currentColor

.tradeAssetAmountRow
  min-height 58px
  margin-top 10px
  display flex
  align-items center
  justify-content space-between
  gap 10px

.tradeAmountInput
  min-width 0
  flex-grow 1
  border none
  outline none
  background transparent
  color var(--color-text-primary)
  font-family 'FiraCode'
  font-size 28px
  line-height 34px
  text-align right
  padding 4px 0

  &::placeholder
    color var(--color-text-disabled)

  &[readonly]
    color var(--color-text-secondary)

.tradeBalanceControls
  min-height 28px
  max-width calc(100% - 110px)
  margin-left auto
  display flex
  align-items center
  justify-content flex-end
  gap 8px
  color var(--color-text-secondary)

.tradeBalanceText
  min-width 0
  overflow hidden
  text-overflow ellipsis
  white-space nowrap
  font-size 12px

.tradeBalanceButtons
  display flex
  align-items center
  gap 5px
  flex-shrink 0

  button
    height 24px
    min-width 46px
    border none
    outline none
    border-radius 6px
    background var(--color-action-primary-subtle)
    color var(--color-action-primary)
    cursor pointer
    font-size 11px
    font-weight 800

    &:hover
      background var(--color-action-primary-border)
      color var(--color-action-primary-hover)

.tradeOutputNote
  min-height 30px
  margin-top 9px
  display flex
  align-items center
  justify-content flex-end
  color var(--color-text-secondary)
  font-size 12px

.tradeQuoteMeta
  min-height 36px
  margin 8px 0
  border 1px solid var(--color-border-subtle)
  border-radius 8px
  color var(--color-text-secondary)
  background var(--color-border-subtle)
  padding 8px 10px
  display flex
  align-items center
  justify-content space-between
  gap 8px
  font-size 12px

  span
    min-width 0
    overflow hidden
    text-overflow ellipsis
    white-space nowrap

.tradeStepTracker
  display flex
  gap 6px
  margin 12px 0 8px 0
  margin-top auto
  padding-top 14px

.tradeStep
  min-width 0
  flex 1
  height 38px
  border 1px solid var(--color-border-subtle)
  border-radius 8px
  background var(--color-border-subtle)
  color var(--color-text-secondary)
  display flex
  align-items center
  gap 6px
  padding 0 8px

  span
    min-width 0
    overflow hidden
    text-overflow ellipsis
    white-space nowrap
    font-size 11px
    font-weight 700

.tradeStepDot
  width 18px
  height 18px
  border-radius 50%
  flex-shrink 0
  display flex
  align-items center
  justify-content center
  background var(--color-border-default)
  color var(--color-text-secondary)
  font-size 10px
  font-weight 800

.tradeSteprequired
  border-color var(--color-action-primary-subtle)

  .tradeStepDot
    background var(--color-action-primary-subtle)
    color var(--color-action-primary)

.tradeAdvanced
  position absolute
  top 0
  right 0
  z-index 22
  margin-top 0

.tradeAdvancedToggle
  width auto
  height 32px
  border 1px solid var(--color-border-subtle)
  outline none
  border-radius 999px
  background var(--color-border-subtle)
  color var(--color-text-secondary)
  display flex
  align-items center
  gap 6px
  padding 0 10px
  cursor pointer
  font-size 12px
  font-weight 700

  &:hover
    background var(--color-bg-hover)
    color var(--color-text-primary)

  > span
    display flex
    align-items center

.tradeAdvancedChevron
  margin-left auto
  display flex
  transform rotate(180deg)

.tradeAdvancedChevronOpen
  transform rotate(0deg)

.tradeAdvancedPanel
  position absolute
  top 40px
  right 0
  width 280px
  border 1px solid var(--color-border-subtle)
  border-radius 8px
  background var(--color-bg-control)
  box-shadow 0 16px 32px var(--color-shadow-default)
  padding 10px

.tradeSettingRow
  min-height 38px
  display flex
  align-items center
  justify-content space-between
  gap 10px
  color var(--color-text-secondary)
  font-size 13px
  font-weight 700

.tradeSlippageInput
  width 96px
  height 32px
  border-radius 7px
  background var(--color-bg-raised)
  display flex
  align-items center
  padding 0 8px
  color var(--color-text-secondary)

  input
    width 100%
    min-width 0
    border none
    outline none
    background transparent
    color var(--color-text-primary)
    font-family 'FiraCode'
    font-size 13px
    text-align right
    padding 0 4px 0 0

.tradeCheckRow
  input
    width 16px
    height 16px
    accent-color var(--color-action-primary)

.tradeFooter
  position absolute
  left 12px
  right 12px
  bottom 12px
  height 62px
  border-radius 8px
  background var(--color-bg-raised)
  border 1px solid var(--color-border-subtle)
  box-shadow 0 12px 28px var(--color-shadow-default)
  display flex
  align-items center
  justify-content center
  padding 8px
  z-index 20

.tradePrimaryButton
  width 100%
  height 46px
  border none
  outline none
  border-radius 8px
  background var(--color-action-primary)
  color var(--color-action-primary-text)
  cursor pointer
  display flex
  align-items center
  justify-content center
  font-size 14px
  font-weight 800

  &:hover
    background var(--color-action-primary-hover)

.tradePrimaryButtonDisabled
  cursor default
  opacity 0.46

@media (max-width: 390px)
  .tradeAmountInput
    font-size 24px

  .tradeStep
    padding 0 6px
