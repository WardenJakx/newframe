.notify
  width 100%
  height 100%
  pointer-events auto
  transition var(--standard)
  display flex
  justify-content center
  align-items center
  text-align center
  opacity 1
  border-radius 10px
  background var(--color-bg-primary)
  
  ::selection
    background var(--color-status-danger)

  .notifyBoxWrap
    border-radius 27px
    box-sizing border-box
    position absolute
    top 6px
    bottom 6px
    left 6px
    right 6px
    transition var(--standard)
    background var(--color-bg-raised)
    display flex
    justify-content center
    align-items center
    text-align center
    opacity 1
    overflow-x hidden
    z-index 4000

    .notifyBoxSlide
      overflow-y scroll
      overflow-x hidden
      max-height 100%
      width 100%
