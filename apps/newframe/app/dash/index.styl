html, body
  margin 0
  border 0
  font-family 'MainFont'
  font-weight 300
  -webkit-app-region no-drag
  overflow hidden
  color var(--color-text-primary)
  background var(--color-bg-primary)

div
  user-select none
  cursor default

::-webkit-scrollbar
  width 0px
  background transparent

@keyframes showFooter
  0%
    opacity 0
    transform translateY(4px)
  60%
    opacity 0
    transform translateY(4px)
  100%
    opacity 1
    transform translateY(0px)

.dash
  width 100%
  height 100%
  overflow-y scroll
  overflow-x hidden
  background var(--color-bg-raised)
  position relative

  .dashMain
    position absolute 
    top 80px
    right 8px
    bottom 40px
    left 8px
    z-index 1000
    background var(--color-bg-primary)
    border-radius 32px
    padding-bottom 20px
    transition var(--standard)

    .dashMainScroll
      position absolute 
      top 0px
      right 0px
      bottom 0px
      left 0px
      z-index 2000
      border-radius 32px
      overflow-y scroll
      overflow-x hidden

    .dashMainOverlay
      position absolute
      top 0px
      right 0px
      bottom 0px
      left 0px
      border-radius 32px
      z-index 40000000
      box-shadow inset 0px 0px 6px var(--color-bg-primary)
      pointer-events none

    .originTitle
      margin 30px 8px 5px 0px
      font-size 18px
      display flex
      align-items center
      font-weight 400

      .originTitleIcon
        margin 9px 16px

      .originTitleText
        margin-top -2px

    .clearOriginsButton
      background var(--color-bg-raised)
      margin 18px 6px 7px 6px
      height 38px
      border-radius 20px
      font-weight 500
      box-sizing border-box
      padding 18px 16px 16px 17px
      text-align center
      margin-bottom 5px
      display flex
      justify-content center
      align-items center
      font-size 13px
      text-transform uppercase
      cursor pointer
      border-bottom 2px solid var(--color-bg-primary)
      box-shadow 0px 2px 4px var(--color-bg-primary)
      letter-spacing 1px
      transform translateY(0px)
      *
        pointer-events none

    .clearOriginsButton:hover
      background var(--color-bg-control)
      box-shadow 0px 4px 8px var(--color-bg-primary)
      transform translateY(-1px)

    .clearOriginsButton:active
      background var(--color-bg-control)
      box-shadow 0px 1px 2px var(--color-bg-primary)
      transform translateY(0px)

  .dashFooter
    background var(--color-bg-primary)
    position absolute
    bottom 40px
    height 60px
    left 8px
    right 8px
    border-radius 30px
    padding 3px 3px 1px 3px
    animation showFooter 0.64s ease-in-out
    box-sizing border-box

    .dashFooterButton
      height 56px
      position relative
      background var(--color-bg-raised)
      border-radius 28px
      display flex
      justify-content center
      align-items center
      cursor pointer
      font-size 16px
      box-shadow 0px 2px 4px var(--color-bg-primary)
      border-bottom 2px solid var(--color-bg-primary)
      box-sizing border-box
      box-sizing border-box
      letter-spacing 1px
      color var(--color-text-primary)
      font-family 'MainFont'
      font-weight 400
      z-index 5
      transform translateY(0px)

      *
        pointer-events none

      .newAccountIcon
        position absolute
        top 0
        left 0
        bottom 0px
        width 64px
        font-size 28px
        display flex
        justify-content center
        align-items center
        font-weight 300
      
  .dashFooterButton:hover
    transform translateY(-1px)
    box-shadow 0px 4px 8px var(--color-bg-primary)
    background var(--color-bg-control)

  .dashFooterButton:active
    transform translateY(0px)
    box-shadow 0px 1px 2px var(--color-bg-primary)
    background var(--color-bg-control)

@import './Dapps/style'
@import './Command/style'
@import './Main/style'
@import './Signer/style'
@import './Notify/style'
@import './Tokens/style'
@import './card.styl'
