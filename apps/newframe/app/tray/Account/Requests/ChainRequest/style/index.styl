.requestChainInner
  display flex
  justify-content center
  align-items center
  flex-direction column
  transform translateZ(0px)
  padding 120px 0px 120px 0px
  margin 16px 4px
  border-radius 20px
  width calc(100% - 16px)
  background var(--color-bg-raised)
  box-shadow 0px 6px 6px var(--color-bg-primary)
  font-family 'MainFont'

.requestChainOriginSub
  width 100%
  font-size 12px
  font-weight 300
  text-transform uppercase
  width 100%
  text-align center
  margin 0px 0px 8px 0px
  color var(--color-action-primary)

.requestChainName
  width calc(100% - 10px)
  margin 0px 0px 20px 0px
  border-radius 12px
  text-align center
  background var(--color-bg-raised)
  font-weight 300
  font-size 26px
  padding 10px 0px