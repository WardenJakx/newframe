._txMain
  position relative
  z-index 100001
  background var(--color-bg-secondary)
  margin 0px 6px 16px 6px
  border-radius 26px
  overflow hidden
  box-shadow 0px 4px 8px var(--color-bg-primary), 0px 2px 8px var(--color-bg-primary)
  border-bottom 2px solid var(--color-bg-primary)
  padding 0

  ._txMainInner
    position relative
    margin 0px 0px
    overflow hidden

  ._txMainTag
    position relative
    z-index 100001
    // animation-name cardShow
    // animation-duration 0.2s
    // animation-fill-mode both
    overflow hidden
    font-size 11px
    font-weight 400
    text-transform uppercase
    letter-spacing 1px
    text-align center
    padding 8px 0px 8px 0px
    margin-top 1px

  ._txMainTagWarning
    color var(--color-status-danger)

  ._txMainTagBad
    color var(--color-status-danger)
  
  ._txMainTagGood
    color var(--color-action-primary)
