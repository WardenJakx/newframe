._txButton
  background var(--color-bg-control)
  border-radius 19px
  transform translateY(0px)
  cursor pointer
  position relative
  overflow hidden

  *
    pointer-events none

._txButton:hover
  // background var(--color-action-primary)
  color var(--color-action-primary-text)
  box-shadow 0px 12px 12px var(--color-bg-primary)
  animation 5s shake ease-in-out infinite alternate

._txButton:hover::after
  content ''
  position absolute
  inset 0
  background var(--color-text-primary)
  background var(--color-action-primary)
  z-index 3

._txButtonBad:hover
  color var(--color-text-inverse)

._txButtonBad:hover::after
  content ''
  position absolute
  inset 0
  background var(--color-text-primary)
  color var(--color-text-inverse)
  background var(--color-status-danger)
  z-index 3

._txButton:active
  transform translateY(0px)
  box-shadow 0px 2px 2px var(--color-shadow-default)

@keyframes shake 
  0% 
    transform translate3d(0px, 0px, 0) rotate(-0.4deg) scale(1)
  25% 
    transform translate3d(-0.7px, -1px, 0) rotate(0.4deg) scale(1.01)
  50% 
    transform translate3d(0.7px, 1px, 0) rotate(-0.4deg) scale(1.02)
  75% 
    transform translate3d(-0.7px, 0.3px, 0) rotate(0.2deg) scale(1.01)
  100% 
    transform translate3d(0.7px, 0.7px, 0) rotate(-0.4deg) scale(1)


.txViewData
  margin 64px 8px
  background var(--color-bg-raised)
  padding 32px 6px 64px 6px
  border-radius 26px
  border-bottom 2px solid var(--color-bg-primary)
  box-shadow 0px 4px 8px var(--color-bg-primary), 0px 2px 8px var(--color-bg-primary)

  .txViewDataHeader
    padding 0px 0px
    margin-bottom 32px
    font-family 'VCR'
    text-transform uppercase
    font-size 18px
    text-align center
    font-weight 400
    letter-spacing 6px
    margin-left 4px
    opacity 1

._txBody
  width 100%
  margin 0px 6px
  padding-top 10px

.txDescriptionSummaryStandalone
  display flex
  justify-content center
  align-items center
  flex-direction column
  padding 18px 6px 20px 6px
  font-size 16px
  font-weight 600
  border-top 2px solid var(--color-bg-primary)
  margin 12px 12px 0px 12px
  font-family VCR
  text-transform uppercase

  div, span
    margin 0px 2px


._txDescription
  width 100%
  font-family 'MainFont'
  font-size 16px
  font-weight 400
  cursor pointer
  padding 12px

  *
    pointer-events none

  ._txDescriptionSummary
    display flex
    justify-content center
    align-items center
    flex-direction column

    ._txDescriptionSummaryMain
      padding 12px
      text-align center

    ._txDescriptionSummaryTag
      font-size 12px
      font-weight 500
      text-transform uppercase
      text-align center
      white-space nowrap
      overflow hidden
      text-overflow ellipsis
      width 300px

    ._txDescriptionSummaryHeadline
      font-size 26px

    ._txDescriptionSummaryMidline
      font-size 12px

.txReview
  width calc(100% - 20px)
  max-width 430px
  margin 0px auto 18px auto
  display flex
  flex-direction column
  gap 10px
  font-family 'MainFont'

.txReviewHero
  background var(--color-bg-primary)
  border-radius 18px
  padding 16px
  box-shadow 0px 2px 8px var(--color-bg-primary)
  border-bottom 2px solid var(--color-border-default)

  .txReviewHeroNetwork
    display inline-flex
    align-items center
    min-height 20px
    padding 0px 8px
    border-radius 10px
    background var(--color-bg-raised)
    font-size 11px
    font-weight 500
    margin-bottom 10px

  .txReviewHeroTitle
    font-size 20px
    font-weight 600
    line-height 24px
    word-break break-word

  .txReviewHeroSubtitle
    margin-top 4px
    font-size 13px
    color var(--color-text-secondary)
    line-height 18px
    word-break break-word

  .txReviewStatus
    margin-top 12px
    display inline-flex
    align-items center
    min-height 24px
    padding 0px 9px
    border-radius 12px
    background var(--color-bg-raised)
    color var(--color-action-primary)
    font-size 11px
    font-weight 600
    text-transform uppercase

  .txReviewNotice
    margin-top 8px
    color var(--color-status-danger)
    font-size 12px
    line-height 17px
    word-break break-word

.txReviewProgress
  position relative
  padding 8px 0px

  .txReviewProgressStep
    position relative
    display grid
    grid-template-columns 28px minmax(0, 1fr)
    min-height 54px

    .txReviewProgressRail
      position absolute
      left 13px
      top 27px
      bottom -27px
      width 2px
      background var(--color-bg-primary)

    .txReviewProgressMarker
      position relative
      z-index 2
      width 28px
      display flex
      justify-content center
      padding-top 8px

    .txReviewProgressMarkerIcon, .txReviewProgressMarkerDot, .txReviewProgressMarkerSpinner
      width 16px
      height 16px
      border-radius 8px
      display flex
      justify-content center
      align-items center
      background var(--color-bg-control)
      color var(--color-text-secondary)

    .txReviewProgressMarkerDot
      box-shadow inset 0px 0px 0px 2px var(--color-shadow-default)

    .txReviewProgressCopy
      min-width 0
      padding 5px 0px 10px 6px

    .txReviewProgressTitle
      font-size 14px
      font-weight 600
      line-height 19px

    .txReviewProgressDetail
      margin-top 2px
      font-size 12px
      line-height 17px
      color var(--color-text-secondary)
      word-break break-word

  .txReviewProgressStep:last-child
    min-height 42px

    .txReviewProgressRail
      display none

  .txReviewProgressStep-complete
    .txReviewProgressRail
      background var(--color-action-primary)

    .txReviewProgressMarkerIcon
      background var(--color-action-primary)
      color var(--color-action-primary-text)

  .txReviewProgressStep-active
    .txReviewProgressMarkerDot, .txReviewProgressMarkerSpinner
      background var(--color-bg-primary)
      box-shadow inset 0px 0px 0px 2px var(--color-action-primary)

    .txReviewProgressTitle
      color var(--color-action-primary)

  .txReviewProgressStep-error
    .txReviewProgressMarkerIcon
      background var(--color-status-danger)
      color var(--color-text-inverse)

    .txReviewProgressTitle
      color var(--color-status-danger)

.txReviewSection, .txReviewFee
  background var(--color-bg-primary)
  border-radius 16px
  box-shadow 0px 1px 5px var(--color-bg-primary)
  overflow hidden

.txReviewSectionTitle
  height 32px
  display flex
  align-items center
  padding 0px 12px
  background var(--color-bg-control)
  color var(--color-text-secondary)
  font-size 12px
  font-weight 600
  text-transform uppercase

.txReviewEffectList, .txReviewDetails
  padding 6px

.txReviewEffect
  min-height 48px
  display grid
  grid-template-columns 28px minmax(0, 1fr) auto
  align-items center
  gap 10px
  border-radius 10px
  padding 8px 10px
  background var(--color-bg-raised)

.txReviewEffect + .txReviewEffect
  margin-top 4px

.txReviewEffectMeta
  min-width 0

.txReviewEffectIcon
  width 26px
  height 26px
  border-radius 13px
  display flex
  align-items center
  justify-content center
  overflow hidden
  background var(--color-bg-control)
  box-shadow inset 0px 0px 0px 1px var(--color-shadow-default)
  color var(--color-text-primary)
  font-size 12px
  font-weight 700

  img
    width 100%
    height 100%
    object-fit cover

  svg
    display block

.txReviewEffectIconSymbolFrame
  width 100%
  height 100%
  display flex
  align-items center
  justify-content center

.txReviewEffectIconSymbol
  display block
  max-width 100%
  line-height 1
  letter-spacing 0
  text-align center
  white-space nowrap
  font-size 9px

.txReviewEffectLabel
  font-size 13px
  font-weight 600

.txReviewEffectDetail
  margin-top 2px
  font-size 11px
  color var(--color-text-secondary)
  line-height 15px
  word-break break-word

.txReviewEffectAmount
  display flex
  align-items center
  justify-content flex-end
  min-width 0
  font-size 14px
  font-weight 600
  color var(--color-action-primary)
  white-space nowrap

  .displayValue
    display flex
    align-items baseline
    min-width 0

  .displayValueMain
    overflow hidden
    text-overflow ellipsis

.txReviewEffect-out
  .txReviewEffectAmount
    color var(--color-status-danger)

.txReviewEffect-neutral
  .txReviewEffectAmount
    color var(--color-text-primary)

.txReviewEffectPrefix
  margin-right 2px

.txReviewEffectEmpty
  min-height 42px
  display flex
  align-items center
  justify-content center
  border-radius 10px
  background var(--color-bg-raised)
  color var(--color-text-secondary)
  font-size 12px
  text-align center

.txReviewDetailRow
  min-height 38px
  display grid
  grid-template-columns 104px minmax(0, 1fr)
  align-items center
  gap 10px
  border-radius 10px
  padding 6px 10px
  background var(--color-bg-raised)

.txReviewDetailRow + .txReviewDetailRow
  margin-top 4px

.txReviewDetailRowClickable
  cursor pointer

.txReviewDetailRowClickable:hover
  background var(--color-bg-control)

.txReviewDetailLabel
  color var(--color-text-secondary)
  font-size 11px
  font-weight 600
  text-transform uppercase

.txReviewDetailValue
  min-width 0
  font-size 12px
  font-family 'FiraCode'
  text-align right
  word-break break-word

.txReviewFeeSummary
  padding 10px 12px
  background var(--color-bg-primary)
  color var(--color-text-primary)
  display grid
  grid-template-columns minmax(0, 1fr) auto
  align-items center
  gap 10px
  font-family 'MainFont'

.txReviewFeeMain
  min-width 0

.txReviewFeeLabel
  color var(--color-text-secondary)
  font-size 11px
  font-weight 600
  text-transform uppercase

.txReviewFeeValue
  margin-top 3px
  font-size 13px
  font-weight 600

  .displayValue
    display flex
    align-items baseline

.txReviewFeeValueWarn
  color var(--color-status-danger)

.txReviewFeeMeta
  display flex
  flex-direction column
  align-items flex-end
  gap 2px
  color var(--color-text-secondary)
  font-size 11px
  line-height 15px
  white-space nowrap

.txReviewFeeRates
  display grid
  grid-template-columns repeat(5, minmax(0, 1fr))
  gap 4px
  padding 0px 8px 8px 8px

.txReviewFeeRate
  appearance none
  border 0
  min-width 0
  height 30px
  border-radius 8px
  background var(--color-bg-raised)
  color var(--color-text-secondary)
  font-family 'MainFont'
  font-size 11px
  font-weight 600
  cursor pointer
  overflow hidden
  text-overflow ellipsis

.txReviewFeeRate:hover
  background var(--color-bg-control)
  color var(--color-text-primary)

.txReviewFeeRateActive
  background var(--color-action-primary)
  color var(--color-action-primary-text)

.txReviewFeeRateActive:hover
  background var(--color-action-primary)
  color var(--color-action-primary-text)

.requestNoticeSigning
  height 116px

.requestNoticeSubmitted
  height 108px

.txSubmittedCommand
  width 100%
  height 100%
  display flex
  align-items center
  justify-content center
  flex-direction column
  position relative

  .requestNoticeInnerText
    position absolute
    top 10px
    left 12px
    right 12px
    padding 0px

  .requestFooter
    position relative
    left auto
    right auto
    bottom auto
    opacity 1
    transform scale(1)
    width calc(100% - 28px)
    margin-top 22px

@media (max-width: 360px)
  .txReviewDetailRow
    grid-template-columns 84px minmax(0, 1fr)

  .txReviewFeeSummary
    grid-template-columns minmax(0, 1fr)

  .txReviewFeeMeta
    align-items flex-start

  .txReviewFeeRates
    grid-template-columns repeat(3, minmax(0, 1fr))

@import '../AdjustFee/style'
