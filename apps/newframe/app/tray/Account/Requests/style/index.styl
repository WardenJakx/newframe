.requestFooter
  font-size 12px
  opacity 0
  transition var(--standard)
  font-family 'MainFont'
  // pointer-events none
  transform translateY(0px) 
  display flex
  justify-content center
  align-items center
  text-transform uppercase
  font-weight 300
  transform scale(0.8)
  position absolute
  bottom 50px
  left 16px
  right 16px
  border-radius 26px
  z-index 99999999
  background var(--color-bg-primary)
  padding 2px

.automaticFeeUpdate
  font-size 12px
  opacity 0
  transition var(--standard)
  font-family 'MainFont'
  transform translateY(0px) 
  display flex
  justify-content center
  align-items center
  text-transform uppercase
  font-weight 300
  transform scale(0.8)
  filter blur(20px)
  background linear-gradient(to top, var(--color-bg-primary) 25%, transparent 100%)
  position absolute
  top -58px
  left 8px
  right 8px
  border-radius 24px
  border-top-right-radius 0px
  border-top-left-radius 0px
  z-index 99999999
  padding-top 8px
  padding-bottom 8px
  pointer-events none

.automaticFeeUpdateActive
  filter blur(0px)
  opacity 1
  pointer-events auto
  transform scale(1)
.txActionButtons
  position relative
  display flex
  flex-wrap wrap
  z-index 999999999
  width 100%
  font-weight 400

  .txActionButtonsRow
    width 100%
    display flex
    justify-content center
    align-items center

    *
      border-radius 6px

    .txActionText:first-child, .txActionButton:first-child
      border-radius 20px
      border-bottom-right-radius 6px
      border-top-right-radius 6px

    .txActionText:last-child, .txActionButton:last-child
      border-radius 20px
      border-bottom-left-radius 6px
      border-top-left-radius 6px

    .txActionText:first-child:last-child, .txActionButton:first-child:last-child
      border-radius 20px

    .txActionText
      background var(--color-bg-raised)
      height 40px
      display flex
      margin 1px
      flex 3
      justify-content center
      align-items center
      padding-top 3px
      box-sizing border-box
      background var(--color-bg-raised)
      box-shadow 0px 1px 2px var(--color-bg-primary)
      border-bottom 2px solid var(--color-bg-primary)

    .txActionButton
      background var(--color-bg-raised)
      box-sizing border-box
      height 40px
      margin 1px
      flex 1
      cursor pointer
      display flex
      justify-content center
      align-items center
      padding-top 3px
      box-sizing border-box
      background var(--color-bg-raised)
      box-shadow 0px 1px 2px var(--color-bg-primary)
    
    .txActionButton:hover
      background var(--color-bg-control)

    .txActionButtonGood
      color var(--color-action-primary)

    .txActionButtonBad
      color var(--color-status-danger)
    
    .txActionButtonDisabled
      color var(--color-text-muted)
      cursor default
    
    .txActionButtonDisabled:hover
      background var(--color-bg-raised)

.requestFooterActive
  filter blur(0px)
  opacity 1
  transform scale(1)
.approveTransaction, .approveRequest
  position absolute
  top 0
  right 0
  bottom 0px
  left 0
  padding 64px 0px
  border-radius 24px
  overflow-y scroll

  .approveRequestHeader
    position absolute
    top 5px
    left 5px
