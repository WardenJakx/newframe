.t2InlineAddStatus
  color var(--color-action-primary)

.t2InlineAddSubmit
  height 44px
  border-radius 22px
  background var(--color-action-primary)
  color var(--color-bg-primary)
  display flex
  align-items center
  justify-content center
  gap 8px
  cursor pointer
  font-size 13px
  font-weight 500

  &:hover
    background var(--color-action-primary-hover)

  *
    pointer-events none

.t2InlineAddSubmitSubtle
  background var(--color-bg-control)
  color var(--color-text-primary)

  &:hover
    background var(--color-bg-hover)

.t2SeedCreateNotice
  min-height 42px
  border-radius 14px
  background var(--color-status-warning-subtle)
  color var(--color-status-warning)
  display flex
  align-items center
  gap 9px
  padding 9px 11px
  font-size 12px
  line-height 17px

.t2SeedCreateNoticeIcon
  color var(--color-status-warning)
  flex-shrink 0

.t2SeedPhraseGrid
  display grid
  grid-template-columns repeat(2, minmax(0, 1fr))
  gap 6px

.t2SeedPhraseWord
  min-width 0
  min-height 34px
  border-radius 10px
  background var(--color-bg-raised)
  display flex
  align-items center
  gap 8px
  padding 7px 9px

  span
    width 17px
    color var(--color-text-muted)
    font-size 10px
    font-family 'FiraCode'
    flex-shrink 0

  strong
    min-width 0
    overflow hidden
    text-overflow ellipsis
    white-space nowrap
    color var(--color-text-primary)
    font-size 12px
    font-family 'FiraCode'
    font-weight 500

.t2SeedPhraseActions
  display flex
  gap 8px
  flex-wrap wrap

.t2SeedBackupCheck
  min-height 42px
  border-radius 14px
  background var(--color-bg-card)
  border 1px solid transparent
  display flex
  align-items center
  gap 10px
  padding 9px 11px
  cursor pointer
  color var(--color-text-secondary)
  font-size 12px

  &:hover
    background var(--color-bg-hover)

  *
    pointer-events none

.t2SeedBackupCheckOn
  border-color var(--color-action-primary-border)
  color var(--color-text-primary)

.t2SeedBackupBox
  height 18px
  width 18px
  border-radius 6px
  border 1px solid var(--color-text-secondary)
  display flex
  align-items center
  justify-content center
  color var(--color-bg-primary)
  flex-shrink 0

.t2SeedBackupCheckOn
  .t2SeedBackupBox
    border-color transparent
    background var(--color-action-primary)

.t2LatticeCreateForm
  display flex
  flex-direction column
  gap 10px
  padding-top 4px

.t2HardwareSignerHeader
  min-height 58px
  border-radius 18px
  background var(--color-bg-card)
  padding 12px
  display flex
  align-items center
  gap 12px

.t2HardwareSignerIcon
  height 34px
  width 34px
  border-radius 17px
  background var(--color-bg-control)
  color var(--color-action-primary)
  display flex
  align-items center
  justify-content center
  flex-shrink 0

.t2HardwareSignerText
  min-width 0
  flex-grow 1
  display flex
  flex-direction column
  gap 4px

.t2HardwareSignerName
  font-size 13px
  font-weight 500
  white-space nowrap
  overflow hidden
  text-overflow ellipsis

.t2HardwareSignerStatus
  font-size 11px
  color var(--color-text-muted)
  font-family 'FiraCode'
  white-space nowrap
  overflow hidden
  text-overflow ellipsis

.t2HardwareChallenge
  border-radius 18px
  background var(--color-bg-card)
  padding 12px
  display flex
  flex-direction column
  gap 10px

.t2HardwarePinDots
  min-height 20px
  display flex
  justify-content center
  align-items center
  gap 7px

  span
    height 7px
    width 7px
    border-radius 50%
    background var(--color-action-primary)

.t2HardwarePinPad
  display grid
  grid-template-columns repeat(3, 1fr)
  gap 8px

.t2HardwarePinButton
  height 38px
  border-radius 12px
  background var(--color-bg-control)
  color var(--color-text-secondary)
  display flex
  align-items center
  justify-content center
  cursor pointer

  &:hover
    background var(--color-bg-hover)
    color var(--color-text-primary)

  *
    pointer-events none

.t2HardwareActions
  display flex
  gap 8px
  flex-wrap wrap

.t2ReceiveOverlay
  z-index 88

.t2ReceiveBody
  flex-grow 1
  display flex
  flex-direction column
  align-items center
  justify-content center
  padding 0 20px 42px 20px

.t2ReceiveIcon
  height 42px
  width 42px
  border-radius 21px
  background var(--color-bg-control)
  color var(--color-action-primary)
  display flex
  align-items center
  justify-content center
  margin-bottom 8px

.t2ReceiveName
  font-size 14px
  font-weight 500
  margin-bottom 18px

.t2ReceiveQr
  width 156px
  height 156px
  border-radius 16px
  overflow hidden
  background var(--color-system-qr-background)
  display flex
  align-items center
  justify-content center
  margin-bottom 16px

.t2ReceiveQrCanvas
  width 156px
  height 156px

.t2ReceiveAddress
  max-width 100%
  height 46px
  border-radius 23px
  background var(--color-bg-raised)
  color var(--color-text-secondary)
  display flex
  align-items center
  gap 8px
  padding 0 13px
  cursor pointer

  &:hover
    background var(--color-bg-hover)
    color var(--color-text-primary)

  span
    min-width 0
    overflow hidden
    text-overflow ellipsis
    white-space nowrap
    font-family 'FiraCode'
    font-size 11px

.t2AssetOverlay
  z-index 88

.t2AssetBody
  flex-grow 1
  padding 8px 16px 112px 16px
  overflow-y auto

.t2AssetHero
  min-height 112px
  display flex
  align-items center
  gap 14px
  border-bottom 1px solid var(--color-border-subtle)
  margin-bottom 12px

.t2AssetHeroIcon
  width 54px
  height 54px
  display flex
  align-items center
  justify-content center
  flex-shrink 0

.t2AssetHeroText
  min-width 0
  flex-grow 1

.t2AssetHeroName
  color var(--color-text-primary)
  font-size 20px
  font-weight 600
  overflow hidden
  text-overflow ellipsis
  white-space nowrap

.t2AssetHeroSub
  display flex
  align-items center
  gap 8px
  margin-top 6px
  color var(--color-text-secondary)
  font-size 13px

  span
    min-width 0
    overflow hidden
    text-overflow ellipsis
    white-space nowrap

.t2AssetDetailList
  display flex
  flex-direction column
  border-top 1px solid var(--color-border-subtle)

.t2AssetDetailRow
  min-height 58px
  display flex
  align-items center
  justify-content space-between
  gap 16px
  border-bottom 1px solid var(--color-border-subtle)

.t2AssetDetailLabel
  color var(--color-text-muted)
  font-size 13px
  font-weight 500
  flex-shrink 0

.t2AssetDetailValue
  color var(--color-text-primary)
  font-size 14px
  font-weight 500
  text-align right
  min-width 0
  overflow hidden
  text-overflow ellipsis
  white-space nowrap

.t2AssetDetailValueCode
  font-family 'FiraCode'
  font-size 10px
  white-space normal
  word-break break-all
  line-height 15px

.t2AssetChainValue
  display flex
  align-items center
  justify-content flex-end
  gap 8px
  min-width 0

  span
    min-width 0
    overflow hidden
    text-overflow ellipsis
    white-space nowrap

.t2AssetChainIcon
  width 22px
  height 22px
  border-radius 50%
  background var(--color-bg-control)
  display flex
  align-items center
  justify-content center
  flex-shrink 0
  overflow hidden

  img
    border-radius 50%
    object-fit cover

.t2AssetFooter
  position absolute
  left 0
  right 0
  bottom 0
  height 94px
  display flex
  align-items center
  justify-content center
  background linear-gradient(180deg, transparent, var(--color-bg-primary) 30%)
  pointer-events none

.t2AssetSendButton
  min-width 132px
  height 48px
  border-radius 24px
  background var(--color-action-primary)
  color var(--color-action-primary-text)
  display flex
  align-items center
  justify-content center
  gap 9px
  font-size 15px
  font-weight 700
  cursor pointer
  pointer-events auto

  &:hover
    background var(--color-action-primary-hover)

  *
    pointer-events none

  > div
    flex-shrink 0

.t2AssetSendButtonDisabled
  opacity 0.45
  cursor default

  &:hover
    background var(--color-action-primary)

.t2LockBlocker
  position absolute
  top 0
  right 0
  bottom 0
  left 0
  z-index 999
  background var(--color-bg-primary)
  display flex
  align-items center
  justify-content center
  padding 18px

.t2LockPanel
  width 100%
  max-width 292px
  border-radius 22px
  background var(--color-bg-card)
  padding 24px 18px 18px 18px
  display flex
  flex-direction column
  align-items center
  gap 12px
  color var(--color-text-primary)

.t2LockIcon
  height 48px
  width 48px
  border-radius 24px
  background var(--color-bg-control)
  color var(--color-action-primary)
  display flex
  align-items center
  justify-content center

.t2LockTitle
  font-size 18px
  font-weight 500

.t2LockInput
  width 100%

  input
    width 100%
    height 42px
    border none
    outline none
    border-radius 21px
    background var(--color-bg-raised)
    color var(--color-text-primary)
    font-family 'MainFont'
    font-size 14px
    text-align center
    box-shadow none

    &::placeholder
      color var(--color-text-muted)

.t2LockError
  color var(--color-status-danger)
  font-size 12px
  line-height 17px
  text-align center

.t2LockSubmit
  width 100%
  height 42px
  border-radius 21px
  background var(--color-action-primary)
  color var(--color-bg-primary)
  display flex
  align-items center
  justify-content center
  cursor pointer
  font-size 13px
  font-weight 500

  &:hover
    background var(--color-action-primary-hover)

.t2LockBiometricSubmit
  background var(--color-bg-control)
  color var(--color-text-primary)
  gap 8px

  &:hover
    background var(--color-bg-hover)

  > div
    color var(--color-action-primary)

// ==================== request view (legacy signing flow) overrides ====================

.t2RequestOverlay
  position absolute
  top 0
  right 0
  bottom 0
  left 0
  background var(--color-bg-primary)
  z-index 100

  .accountView
    top 10px !important

@import '../features/tokens/style'
