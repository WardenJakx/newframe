  flex-direction column
  gap 10px

.t2HardwarePinDots
  min-height 20px
  display flex
  justify-content center
  align-items center
  gap 7px

  span
    height 7px
    width 7px
    border-radius 50%
    background $t2-teal

.t2HardwarePinPad
  display grid
  grid-template-columns repeat(3, 1fr)
  gap 8px

.t2HardwarePinButton
  height 38px
  border-radius 12px
  background $t2-button
  color $t2-muted-strong
  display flex
  align-items center
  justify-content center
  cursor pointer

  &:hover
    background $t2-button-hover
    color $t2-text

  *
    pointer-events none

.t2HardwareActions
  display flex
  gap 8px
  flex-wrap wrap

.t2ReceiveOverlay
  z-index 88

.t2ReceiveBody
  flex-grow 1
  display flex
  flex-direction column
  align-items center
  justify-content center
  padding 0 20px 42px 20px

.t2ReceiveIcon
  height 42px
  width 42px
  border-radius 21px
  background $t2-button
  color $t2-teal
  display flex
  align-items center
  justify-content center
  margin-bottom 8px

.t2ReceiveName
  font-size 14px
  font-weight 500
  margin-bottom 18px

.t2ReceiveQr
  width 156px
  height 156px
  border-radius 16px
  overflow hidden
  background white
  display flex
  align-items center
  justify-content center
  margin-bottom 16px

.t2ReceiveQrCanvas
  width 156px
  height 156px

.t2ReceiveAddress
  max-width 100%
  height 46px
  border-radius 23px
  background $t2-pill
  color $t2-muted-strong
  display flex
  align-items center
  gap 8px
  padding 0 13px
  cursor pointer

  &:hover
    background $t2-pill-hover
    color $t2-text

  span
    min-width 0
    overflow hidden
    text-overflow ellipsis
    white-space nowrap
    font-family 'FiraCode'
    font-size 11px

.t2AssetOverlay
  z-index 88

.t2AssetBody
  flex-grow 1
  padding 8px 16px 112px 16px
  overflow-y auto

.t2AssetHero
  min-height 112px
  display flex
  align-items center
  gap 14px
  border-bottom 1px solid $t2-divider
  margin-bottom 12px

.t2AssetHeroIcon
  width 54px
  height 54px
  display flex
  align-items center
  justify-content center
  flex-shrink 0

  .t2TokenIconInner
    height 48px
    width 48px

  .t2TokenChainBadge
    top -6px
    left -6px

.t2AssetHeroText
  min-width 0
  flex-grow 1

.t2AssetHeroName
  color $t2-text
  font-size 20px
  font-weight 600
  overflow hidden
  text-overflow ellipsis
  white-space nowrap

.t2AssetHeroSub
  display flex
  align-items center
  gap 8px
  margin-top 6px
  color $t2-muted-strong
  font-size 13px

  span
    min-width 0
    overflow hidden
    text-overflow ellipsis
    white-space nowrap

.t2AssetDetailList
  display flex
  flex-direction column
  border-top 1px solid $t2-divider

.t2AssetDetailRow
  min-height 58px
  display flex
  align-items center
  justify-content space-between
  gap 16px
  border-bottom 1px solid $t2-divider

.t2AssetDetailLabel
  color $t2-muted
  font-size 13px
  font-weight 500
  flex-shrink 0

.t2AssetDetailValue
  color $t2-text
  font-size 14px
  font-weight 500
  text-align right
  min-width 0
  overflow hidden
  text-overflow ellipsis
  white-space nowrap

.t2AssetDetailValueCode
  font-family 'FiraCode'
  font-size 10px
  white-space normal
  word-break break-all
  line-height 15px

.t2AssetChainValue
  display flex
  align-items center
  justify-content flex-end
  gap 8px
  min-width 0

  span
    min-width 0
    overflow hidden
    text-overflow ellipsis
    white-space nowrap

.t2AssetChainIcon
  width 22px
  height 22px
  border-radius 50%
  background $t2-button
  display flex
  align-items center
  justify-content center
  flex-shrink 0
  overflow hidden

  img
    border-radius 50%
    object-fit cover

.t2AssetFooter
  position absolute
  left 0
  right 0
  bottom 0
  height 94px
  display flex
  align-items center
  justify-content center
  background linear-gradient(180deg, rgba(18, 14, 20, 0), $t2-bg 30%)
  pointer-events none

.t2AssetSendButton
  min-width 132px
  height 48px
  border-radius 24px
  background $t2-teal
  color rgb(8, 16, 18)
  display flex
  align-items center
  justify-content center
  gap 9px
  font-size 15px
  font-weight 700
  cursor pointer
  pointer-events auto

  &:hover
    background $t2-teal-bright

  *
    pointer-events none

  > div
    flex-shrink 0

.t2AssetSendButtonDisabled
  opacity 0.45
  cursor default

  &:hover
    background $t2-teal

.t2LockBlocker
  position absolute
  top 0
  right 0
  bottom 0
  left 0
  z-index 999
  background $t2-bg
  display flex
  align-items center
  justify-content center
  padding 18px

.t2LockPanel
  width 100%
  max-width 292px
  border-radius 22px
  background $t2-card
  padding 24px 18px 18px 18px
  display flex
  flex-direction column
  align-items center
  gap 12px
  color $t2-text

.t2LockIcon
  height 48px
  width 48px
  border-radius 24px
  background $t2-button
  color $t2-teal
  display flex
  align-items center
  justify-content center

.t2LockChecking
  height 48px
  width 48px
  border-radius 24px
  background $t2-card
  display flex
  align-items center
  justify-content center

.t2LockSpinner
  height 18px
  width 18px
  border-radius 50%
  border 2px solid rgba(255, 255, 255, 0.16)
  border-top-color $t2-teal
  animation t2Spin 0.8s infinite linear

.t2LockTitle
  font-size 18px
  font-weight 500

.t2LockInput
  width 100%

  input
    width 100%
    height 42px
    border none
    outline none
    border-radius 21px
    background $t2-pill
    color $t2-text
    font-family 'MainFont'
    font-size 14px
    text-align center
    box-shadow none

    &::placeholder
      color $t2-muted

.t2LockError
  color $t2-pink
  font-size 12px
  line-height 17px
  text-align center

.t2LockSubmit
  width 100%
  height 42px
  border-radius 21px
  background $t2-teal
  color $t2-bg
  display flex
  align-items center
  justify-content center
  cursor pointer
  font-size 13px
  font-weight 500

  &:hover
    background $t2-teal-bright

.t2LockBiometricSubmit
  background $t2-button
  color $t2-text
  gap 8px

  &:hover
    background $t2-button-hover

  > div
    color $t2-teal

// ==================== request view (legacy signing flow) overrides ====================

.t2RequestOverlay
  position absolute
  top 0
  right 0
  bottom 0
  left 0
  background $t2-bg
  z-index 100

  .accountView
    top 10px !important
