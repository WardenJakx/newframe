// Newframe Tray v2 - modernized home view
@keyframes t2RiseIn
  0%
    opacity 0
    transform translateY(8px)
  100%
    opacity 1
    transform translateY(0px)

@keyframes t2AppearBlur
  0%
    filter blur(10px)
    opacity 0
  100%
    filter blur(0px)
    opacity 1

@keyframes t2Spin
  0%
    transform rotate(0deg)
  100%
    transform rotate(360deg)

.t2Home
  position absolute
  top 0
  right 0
  bottom 0
  left 0
  display flex
  flex-direction column

// ==================== settings dropdown ====================

// keep main content in its own stacking layer below the dropdown/overlays so
// composited text layers (post-animation) can't paint through them
.t2Hero,
.t2TabRow,
.t2SearchWrap,
.t2Main
  position relative
  z-index 1

.statusGlyph
  width 24px
  height 24px
  border-radius 50%
  display flex
  align-items center
  justify-content center
  flex-shrink 0

.statusGlyph-small
  width 16px
  height 16px

.statusGlyph-pending
  color var(--color-action-primary)

.statusGlyph-completed
  color var(--color-action-primary)
  background var(--color-action-primary-subtle)

.statusGlyph-failed
  color var(--color-status-danger)
  background var(--color-action-danger-subtle)

.statusGlyphSpinner
  width 16px
  height 16px
  border 2px solid var(--color-action-primary-subtle)
  border-top-color var(--color-action-primary)
  border-radius 50%
  animation t2Spin 900ms linear infinite

.statusGlyph-small .statusGlyphSpinner
  width 13px
  height 13px
  border-width 2px

.statusGlyphDot
  width 6px
  height 6px
  border-radius 50%
  background var(--color-text-muted)

.t2StatusNotifications
  position relative
  z-index 2
  display flex
  flex-direction column
  gap 7px
  padding 10px 18px 0 18px
  pointer-events none
  animation t2RiseIn 160ms ease-out both

.t2StatusNotification
  min-height 58px
  display grid
  grid-template-columns 28px 22px minmax(0, 1fr) auto 24px
  align-items center
  gap 9px
  padding 8px 9px 8px 11px
  border 1px solid var(--color-border-default)
  border-radius 7px
  background var(--color-bg-primary)
  box-shadow 0px 10px 28px var(--color-shadow-default)
  pointer-events auto
  cursor pointer

  &:hover
    background var(--color-bg-card)

  *
    pointer-events none

.t2StatusNotification-failed
  border-color var(--color-action-danger-border)

.t2StatusNotification-completed
  border-color var(--color-action-primary-border)

.t2StatusNotificationChain
  width 20px
  height 20px
  display flex
  align-items center
  justify-content center
  color var(--color-text-secondary)

.t2StatusNotificationCopy
  min-width 0
  display flex
  flex-direction column
  gap 2px

.t2StatusNotificationTopline
  display flex
  align-items center
  gap 7px
  min-width 0
  font-size 12px
  font-weight 500
  color var(--color-text-primary)

  span
    white-space nowrap
    overflow hidden
    text-overflow ellipsis

  span:first-child
    color var(--color-text-secondary)
    flex-shrink 0

.t2StatusNotificationDetail
  min-width 0
  font-size 10px
  font-family 'FiraCode'
  color var(--color-text-muted)
  white-space nowrap
  overflow hidden
  text-overflow ellipsis

.t2StatusNotificationTimestamp
  align-self start
  padding-top 7px
  font-size 9px
  font-family 'FiraCode'
  color var(--color-text-muted)
  white-space nowrap
  text-align right

.t2StatusNotificationDismiss
  grid-column 5
  width 22px
  height 22px
  border-radius 50%
  display flex
  align-items center
  justify-content center
  color var(--color-text-muted)
  pointer-events auto
  cursor pointer

  &:hover
    background var(--color-bg-hover)
    color var(--color-text-primary)

.t2SettingsScroll
  padding 0 14px 28px 14px

.t2SettingsSection
  display flex
  flex-direction column
  gap 8px
  margin-bottom 18px

.t2SettingsSectionTitle
  padding 0 4px
  color var(--color-text-muted)
  font-size 11px
  font-weight 500
  letter-spacing 0
  text-transform uppercase

.t2SettingsRow
  min-height 58px
  border-radius 18px
  background var(--color-bg-card)
  padding 12px
  display flex
  align-items center
  justify-content space-between
  gap 12px
  flex-shrink 0

.t2SettingsSelectRow,
.t2SettingsActionRow
  cursor pointer

  &:hover
    background var(--color-bg-hover)

  *
    pointer-events none

.t2SettingsRowText
  display flex
  flex-direction column
  gap 4px
  min-width 0
  flex-grow 1

.t2SettingsRowTitle
  font-size 13px
  font-weight 500
  white-space nowrap
  overflow hidden
  text-overflow ellipsis

.t2SettingsRowDetail
  font-size 11px
  color var(--color-text-muted)
  line-height 16px

.t2SettingsRowValue
  display flex
  align-items center
  gap 7px
  color var(--color-text-secondary)
  font-family 'FiraCode'
  font-size 11px
  flex-shrink 0

.t2SettingsActionValue
  color var(--color-action-primary)
  font-family 'FiraCode'
  font-size 11px
  flex-shrink 0

.t2SettingsDangerRow .t2SettingsActionValue,
.t2SettingsDangerButton
  color var(--color-status-danger)

.t2SettingsShortcutRow
  flex-direction column
  align-items stretch

.t2SettingsShortcutTop
  display flex
  align-items center
  justify-content space-between
  gap 12px

.t2SettingsShortcutControls
  display flex
  align-items center
  gap 10px
  flex-shrink 0

.t2SettingsSmallButton
  height 28px
  padding 0 12px
  border-radius 14px
  background var(--color-bg-control)
  display flex
  align-items center
  justify-content center
  cursor pointer
  font-size 11px
  font-weight 500

  &:hover
    background var(--color-bg-hover)

.t2SettingsShortcutDetails
  color var(--color-text-secondary)
  font-size 12px
  line-height 18px

  span
    display flex
    align-items center
    flex-wrap wrap
    gap 6px

  label
    color var(--color-text-muted)

  .keyCommand
    min-height 24px
    border-radius 8px
    background var(--color-bg-primary)
    color var(--color-text-primary)
    padding 3px 8px
    font-family 'FiraCode'
    font-size 11px

.t2SettingsInputRow
  height 42px
  border-radius 18px
  background var(--color-bg-raised)
  display flex
  align-items center
  padding 0 12px

  input
    width 100%
    border none
    outline none
    background transparent
    color var(--color-text-primary)
    font-family 'FiraCode'
    font-size 12px
    cursor text

    &::placeholder
      color var(--color-text-muted)

.t2SettingsConfirmActions
  display flex
  gap 8px
  flex-shrink 0

.t2InfoRow
  min-height 58px
  border-radius 18px
  background var(--color-bg-card)
  padding 12px
  display flex
  flex-direction column
  gap 6px

.t2InfoCopyRow
  cursor pointer

  &:hover
    background var(--color-bg-hover)

.t2InfoLabel
  font-size 11px
  color var(--color-text-muted)
  text-transform uppercase
  letter-spacing 0

.t2InfoValue
  font-size 13px
  color var(--color-text-primary)
  overflow hidden
  text-overflow ellipsis
  white-space nowrap

.t2InfoValueMono
  font-family 'FiraCode'
  font-size 11px

.loaderWrap
  width 18px
  height 18px
  margin-left 4px

.loader,
.loader:after
  border-radius 100%
  width 7em
  height 7em

.loader
  font-size 2px
  position relative
  text-indent -9999em
  border-top 2px solid var(--color-text-disabled)
  border-right 2px solid var(--color-text-disabled)
  border-bottom 2px solid var(--color-text-disabled)
  border-left 2px solid var(--color-action-primary)
  transform translateZ(0)
  animation t2Spin 1.1s infinite linear !important

// ==================== toggles ====================

.t2Toggle
  position relative
  background var(--color-status-danger)
  height 20px
  width 40px
  border-radius 10px
  transition 0.32s cubic-bezier(0.82, 0, 0.12, 1) all
  cursor pointer
  flex-shrink 0

.t2ToggleOn
  background var(--color-action-primary)

.t2ToggleKnob
  position absolute
  top 2px
  left 2px
  bottom 2px
  width 16px
  border-radius 10px
  transition 0.32s cubic-bezier(0.82, 0, 0.12, 1) all
  background var(--color-bg-hover)
  pointer-events none

.t2ToggleOn .t2ToggleKnob
  transform translateX(20px)

// ==================== hero ====================

.t2Hero
  padding 32px 20px 24px 20px
  flex-shrink 0
  display flex
  flex-direction column
  align-items center
  gap 22px

.t2HeroValue
  position relative
  display flex
  align-items baseline
  justify-content center
  font-family 'FiraCode'
  animation t2AppearBlur 600ms cubic-bezier(0.82, 0, 0.12, 1) both

  &:after
    content ''
    position absolute
    left 100%
    top 0
    bottom 0
    width 52px

  &:hover .t2HeroRefresh
    opacity 1
    pointer-events auto

.t2HeroDollars
  font-size 46px
  font-weight 400
  letter-spacing 0

.t2HeroCents
  font-size 24px
  font-weight 300
  letter-spacing 0
  color var(--color-text-muted)

.t2HeroRefresh
  position absolute
  left 100%
  top 50%
  height 34px
  width 34px
  margin-left 12px
  border-radius 17px
  background var(--color-bg-control)
  color var(--color-action-primary)
  display flex
  justify-content center
  align-items center
  cursor pointer
  opacity 0
  pointer-events none
  z-index 2
  transform translateY(-50%)
  transition 0.12s ease-out all

  &:hover
    background var(--color-bg-hover)
    color var(--color-action-primary-hover)

  *
    pointer-events none

.t2HeroRefreshActive
  opacity 1
  pointer-events none

  > div
    animation t2Spin 0.7s infinite linear

.t2HeroActions
  display flex
  justify-content center
  gap 10px

.t2HeroButton
  width 134px
  height 46px
  border-radius 23px
  background var(--color-bg-control)
  display flex
  justify-content center
  align-items center
  gap 9px
  cursor pointer
  border-bottom 2px solid var(--color-bg-primary)
  font-size 14px
  font-weight 400

  &:hover
    background var(--color-bg-hover)
    transform translateY(-1px)

  &:active
    transform translateY(0px)

  *
    pointer-events none

.t2HeroButtonDisabled
  opacity 0.45
  cursor default
  color var(--color-text-muted)

  &:hover
    background var(--color-bg-control)
    transform none

  &:active
    transform none

  .t2HeroButtonIcon
    color var(--color-text-muted)

.t2HeroButtonIcon
  color var(--color-action-primary)
  display flex

// ==================== tabs + network filter ====================

.t2TabRow
  display flex
  align-items center
  justify-content space-between
  padding 0 18px 10px 18px
  flex-shrink 0

.t2Tabs
  display flex
  gap 18px

.t2Tab
  display flex
  flex-direction column
  align-items center
  gap 5px
  cursor pointer

  *
    pointer-events none

.t2TabLabel
  font-size 14px
  font-weight 500
  color var(--color-text-muted)

.t2TabLabelActive
  color var(--color-text-primary)

.t2TabBar
  width 100%
  height 3px
  border-radius 2px
  background transparent

.t2TabBarActive
  background var(--color-action-primary)

.t2NetworkPill
  height 34px
  border-radius 17px
  background var(--color-bg-raised)
  display flex
  align-items center
  gap 7px
  padding 0 11px 0 12px
  cursor pointer

  &:hover
    background var(--color-bg-hover)

  *
    pointer-events none

  span
    font-size 12px
    font-weight 400

.t2NetworkPillChevron
  color var(--color-text-muted)
  display flex
  transform rotate(180deg)

.t2NetworkDots
  display grid
  grid-template-columns 5px 5px
  gap 2px

  .t2NetworkDotSmall
    width 5px
    height 5px
    border-radius 50%

.t2NetworkDotsLarge
  grid-template-columns 8px 8px
  gap 3px
  padding 4px

  .t2NetworkDotSmall
    width 8px
    height 8px

.t2PillChainIcon
  display flex
  justify-content center
  align-items center

  img
    border-radius 50%
    object-fit cover

// ==================== asset search ====================

.t2SearchWrap
  padding 0 14px 10px 14px
  flex-shrink 0

.t2Search
  height 38px
  border-radius 19px
  background var(--color-bg-raised)
  display flex
  align-items center
  gap 9px
  padding 0 6px 0 14px

  input
    flex-grow 1
    border none
    outline none
    background transparent
    color var(--color-text-primary)
    font-size 13px
    font-family 'MainFont'
    box-shadow none
    cursor text
    padding 0

    &::placeholder
      color var(--color-text-muted)

.t2SearchIcon
  color var(--color-text-muted)
  display flex

.t2SearchClear
  height 28px
  width 28px
  border-radius 50%
  display flex
  justify-content center
  align-items center
  cursor pointer
  color var(--color-text-muted)

  &:hover
    background var(--color-bg-hover)

  *
    pointer-events none

// ==================== main list ====================

.t2Main
  flex-grow 1
  overflow-y scroll
  overflow-x hidden
  padding 2px 10px 24px 10px

.t2List
  display flex
  flex-direction column

.t2TokenRow
  display flex
  align-items center
  gap 12px
  padding 10px 8px
  border-radius 18px
  cursor pointer

  &:hover
    background var(--color-bg-card)

  *
    pointer-events none

.t2ChainIconDot
  border-radius 50%

.t2LowValueHidden
  margin 6px 8px 2px 8px
  padding 9px 12px
  border-radius 4px
  background var(--color-border-default)
  color var(--color-text-muted)
  display flex
  align-items center
  gap 8px
  cursor pointer
  font-size 13px
  font-weight 500
  letter-spacing 0

  &:hover
    background var(--color-border-default)

  *
    pointer-events none

.t2LowValueHiddenChevron
  display flex
  color var(--color-text-muted)
  transform rotate(180deg)

.t2LowValueHiddenChevronOpen
  transform rotate(270deg)

.t2LowValueHiddenLabel
  flex-grow 1
  min-width 0

.t2LowValueHiddenValue
  color var(--color-text-primary)
  font-family 'FiraCode'
  font-size 13px
  font-weight 600

.t2DustTokenRow
  margin-left 0
  background var(--color-border-subtle)

.t2SecondaryTokenRow
  margin-left 0
  background var(--color-border-subtle)

.t2PositionListMore
  margin 6px 8px
  padding 9px 12px
  border-radius 4px
  background var(--color-border-subtle)
  color var(--color-text-muted)
  display flex
  align-items center
  justify-content center
  gap 8px
  cursor pointer
  font-size 12px
  font-weight 500

  &:hover
    background var(--color-border-default)

  *
    pointer-events none

.t2ActivityList
  display flex
  flex-direction column
  gap 4px

.t2ActivityRow
  min-height 62px
  display flex
  align-items center
  gap 11px
  padding 9px 8px
  border-radius 8px
  cursor pointer

  &:hover
    background var(--color-bg-card)

  *
    pointer-events none

.t2ActivityIconWrap
  position relative
  width 38px
  height 38px
  border-radius 50%
  background var(--color-bg-control)
  border 1px solid var(--color-border-default)
  display flex
  align-items center
  justify-content center
  flex-shrink 0

.t2ActivityChainBadge
  position absolute
  top -6px
  left -6px
  width 20px
  height 20px
  border-radius 50%
  border 2px solid var(--color-bg-primary)
  background var(--color-bg-control)
  display flex
  align-items center
  justify-content center
  overflow hidden

  img
    border-radius 50%
    object-fit cover

.t2ActivityCopy
  min-width 0
  flex-grow 1
  display flex
  flex-direction column
  gap 4px

.t2ActivityTitle
  font-size 14px
  font-weight 500
  color var(--color-text-primary)
  white-space nowrap
  overflow hidden
  text-overflow ellipsis

.t2ActivitySubtitle
  display flex
  align-items center
  gap 8px
  min-width 0
  font-size 10px
  font-family 'FiraCode'
  color var(--color-text-muted)

  span
    white-space nowrap
    overflow hidden
    text-overflow ellipsis

.t2ActivityMeta
  min-width 82px
  display flex
  flex-direction column
  align-items flex-end
  gap 4px

.t2ActivityStatus
  font-size 11px
  font-weight 500
  color var(--color-text-secondary)

.t2ActivityStatus-succeeded
  color var(--color-action-primary)

.t2ActivityStatus-reverted
  color var(--color-status-danger)

.t2ActivityTime
  font-size 10px
  font-family 'FiraCode'
  color var(--color-text-muted)

.t2ActivityOverlay
  z-index 88

.t2ActivityDetailScroll
  padding 0 12px 28px 12px

  .txReview
    padding-bottom 0

.t2OrderList
  display flex
  flex-direction column
  gap 4px

.t2OrderRow
  min-height 74px
  display grid
  grid-template-columns 22px 70px minmax(0, 1fr) minmax(62px, auto)
  grid-template-areas "cancel status copy size" "cancel asset copy contra"
  align-items center
  column-gap 9px
  row-gap 5px
  padding 9px 8px
  border-radius 8px
  cursor pointer

  &:hover
    background var(--color-bg-card)

.t2OrderCancelSlot
  grid-area cancel
  width 22px
  display flex
  align-items center
  justify-content center

.t2OrderCancel
  width 20px
  height 20px
  border-radius 50%
  display flex
  align-items center
  justify-content center
  color var(--color-text-muted)
  background var(--color-border-subtle)
  cursor pointer

  &:hover
    color var(--color-status-danger)
    background var(--color-action-danger-subtle)

  *
    pointer-events none

.t2OrderStatusBlock
  grid-area status
  min-width 0
  display flex
  flex-direction column
  gap 3px

.t2OrderStatus
  font-size 11px
  font-weight 500
  color var(--color-text-secondary)
  white-space nowrap
  overflow hidden
  text-overflow ellipsis

.t2OrderStatus-open,
.t2OrderStatus-pending,
.t2OrderStatus-submitted,
.t2OrderStatus-accepted,
.t2OrderStatus-active,
.t2OrderStatus-working,
.t2OrderStatus-created,
.t2OrderStatus-filled,
.t2OrderStatus-complete,
.t2OrderStatus-completed
  color var(--color-action-primary)

.t2OrderStatus-cancelled,
.t2OrderStatus-canceled,
.t2OrderStatus-failed,
.t2OrderStatus-rejected,
.t2OrderStatus-expired
  color var(--color-status-danger)

.t2OrderCreated
  font-size 10px
  font-family 'FiraCode'
  color var(--color-text-muted)
  white-space nowrap

.t2OrderAssetColumn
  grid-area asset
  min-width 0

.t2OrderCopy
  grid-area copy
  min-width 0
  display flex
  flex-direction column
  gap 4px

.t2OrderIntent
  font-size 14px
  font-weight 500
  color var(--color-text-primary)
  white-space nowrap
  overflow hidden
  text-overflow ellipsis

.t2OrderSubline
  display flex
  align-items center
  gap 8px
  min-width 0
  font-size 10px
  font-family 'FiraCode'
  color var(--color-text-muted)

  span
    white-space nowrap
    overflow hidden
    text-overflow ellipsis

.t2OrderCancelInlineError
  color var(--color-status-danger)

.t2OrderSize
  grid-area size
  justify-self end
  max-width 96px
  font-size 11px
  font-family 'FiraCode'
  color var(--color-text-secondary)
  white-space nowrap
  overflow hidden
  text-overflow ellipsis

.t2OrderContra
  grid-area contra
  justify-self end
  min-width 0
  max-width 120px

.t2OrderAssetPill
  min-width 0
  display inline-flex
  align-items center
  gap 5px
  color var(--color-text-secondary)
  font-size 11px
  font-family 'FiraCode'
  white-space nowrap

  > span:last-child
    min-width 0
    overflow hidden
    text-overflow ellipsis

.t2OrderAssetPrefix
  color var(--color-text-muted)
  font-family 'MainFont'
  font-size 10px

.t2OrderAssetIcon
  position relative
  width 24px
  height 24px
  flex-shrink 0

.t2OrderAssetIconInner
  width 24px
  height 24px
  border-radius 50%
  background var(--color-bg-control)
  border 1px solid var(--color-border-default)
  display flex
  align-items center
  justify-content center
  color var(--color-action-primary)
  overflow hidden

  img
    width 100%
    height 100%
    object-fit cover

  span
    color var(--color-text-primary)
    font-size 10px
    font-weight 600
    font-family 'FiraCode'

.t2OrderAssetChainBadge
  position absolute
  top -5px
  left -5px
  width 14px
  height 14px
  border-radius 50%
  border 2px solid var(--color-bg-primary)
  background var(--color-bg-control)
  display flex
  align-items center
  justify-content center
  overflow hidden

  img
    border-radius 50%
    object-fit cover

.t2OrderOverlay
  z-index 88

.t2OrderDetailScroll
  padding 0 12px 28px 12px

.t2OrderDetailHero
  border-radius 8px
  background var(--color-bg-card)
  padding 13px
  margin-bottom 10px
  display flex
  flex-direction column
  gap 10px

.t2OrderDetailPair
  display grid
  grid-template-columns minmax(0, auto) minmax(0, 1fr) minmax(0, auto)
  align-items center
  gap 10px

.t2OrderDetailIntent
  min-width 0
  text-align center
  font-size 15px
  font-weight 500
  color var(--color-text-primary)
  white-space nowrap
  overflow hidden
  text-overflow ellipsis

.t2OrderDetailMeta
  display flex
  align-items center
  flex-wrap wrap
  gap 7px
  color var(--color-text-muted)
  font-size 11px
  font-family 'FiraCode'

  span
    min-height 22px
    border-radius 4px
    background var(--color-border-subtle)
    padding 4px 7px

.t2OrderDetailList
  display flex
  flex-direction column
  gap 7px

.t2OrderDetailRow
  min-height 44px
  border-radius 8px
  background var(--color-border-subtle)
  padding 9px 10px
  display flex
  align-items center
  justify-content space-between
  gap 12px

.t2OrderDetailLabel
  color var(--color-text-muted)
  font-size 11px
  text-transform uppercase
  letter-spacing 0
  flex-shrink 0

.t2OrderDetailValue
  min-width 0
  color var(--color-text-primary)
  font-size 12px
  text-align right
  overflow hidden
  text-overflow ellipsis
  white-space nowrap

.t2OrderDetailValueCode
  font-family 'FiraCode'
  font-size 10px

.t2OrderChainValue
  display inline-flex
  align-items center
  justify-content flex-end
  gap 6px
  min-width 0

.t2OrderChainIcon
  width 18px
  height 18px
  display flex
  align-items center
  justify-content center
  flex-shrink 0
  overflow hidden

  img
    border-radius 50%
