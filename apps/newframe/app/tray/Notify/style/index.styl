.notify
  position fixed
  top 0px
  right 0px
  left 0px
  bottom 0px
  z-index 9999999999999999
  pointer-events auto
  transition var(--standard)
  display flex
  justify-content center
  align-items center
  text-align center
  opacity 1
  background var(--color-bg-primary)
  
  ::selection
    background var(--color-status-danger)

  .notifyBoxWrap
    border-radius 12px
    position absolute
    top 0px
    bottom 0px
    left 0px
    right 0px
    padding 8px
    transition var(--standard)
    background var(--color-bg-primary)
    display flex
    justify-content center
    align-items center
    text-align center
    opacity 1
    overflow-x hidden
    z-index 4000000000

    .notifyBoxSlide
      overflow-y scroll
      overflow-x hidden
      max-height 100%
      width 100%

    .notifyBox
      width 100%
      overflow hidden

      .notifyTitle
        font-size 19px
        position relative
        z-index 3
        margin-bottom 40px
        color var(--color-status-danger)

      .notifyBody
        font-size 14px
        position relative
        z-index 3
        word-break break-word
        width 100%
        padding 8px

        .notifyBodyLine
          padding 0px 20px
          font-size 16px
          font-weight 300
          font-family 'MainFont'

        .notifyBodyUpdate
          padding 8px
          margin-bottom 8px
          background var(--color-status-danger)
          color var(--color-text-inverse)
          border-radius 8px
          margin-top 50px
          font-size 13px
          font-weight 300

        .notifyBodyHash
          font-size 14px
          font-family 'FiraCode'
          background var(--color-bg-control)
          line-height 20px
          box-shadow inset 0px 2px 14px var(--color-bg-control)
          padding 18px
          border-radius 12px
          margin-top 28px
          border 1px solid var(--color-bg-hover)
          text-shadow 0px 2px 0px var(--color-bg-control)
          max-height 58px

        .notifyBodyPrice
          margin-top 4px
          font-size 23px

        .notifyBodyQuestion
          padding-top 40px
          color var(--color-status-danger)

      .notifyCheck
        display flex
        position relative
        justify-content center
        align-items center
        font-weight 400
        z-index 3
        margin-top 16px
        margin-left 8px
        padding 0px 30px

        .notifyCheckBox 
          width 32px
          height 32px
          min-width 32px
          min-height 32px
          border-radius 16px
          background var(--color-bg-hover)
          border 1px solid var(--color-bg-primary)
          box-shadow 0px 1px 1px var(--color-shadow-subtle), 0px 2px 1px var(--color-bg-raised), 0px 0px 7px 2px var(--color-bg-control)
          margin-right 10px
          display flex
          position relative
          justify-content center
          align-items center
          cursor pointer
          *
            pointer-events none

          svg 
            height 22px

        .notifyCheckBox:hover
          background var(--color-bg-hover)

        .notifyCheckText
          text-align left
          font-size 13px
          line-height 13px
          width 210px

      .notifyInput
        display flex
        position relative
        justify-content space-between
        z-index 3
        margin 40px 8px 0px 8px

        .notifyInputOption
          position relative
          width calc(50% - 1px)
          display flex
          justify-content center
          align-items center
          background var(--color-bg-raised)
          height 40px
          font-weight 300
          padding-top 1px
          box-shadow 0px 1px 1px var(--color-shadow-subtle), 0px 2px 1px var(--color-bg-raised), 0px 0px 7px 2px var(--color-bg-control)
          text-transform uppercase
          font-size 14px
          font-weight 400
          letter-spacing 1px
          cursor pointer
          *
            pointer-events none

          .notifyInputOptionText
            position relative
            z-index 200
            padding-bottom 2px

        .notifyInputOption:hover:before
          background var(--color-bg-hover)

        .notifyInputDeny:before
          content ''
          position absolute
          top 0
          left 0
          right 0
          bottom 2px
          background var(--color-bg-control)
          z-index 2
          border-top-left-radius 19px
          border-bottom-left-radius 19px

        .notifyInputDeny
          border-top-left-radius 20px
          border-bottom-left-radius 20px

        .notifyInputProceed:before
          content ''
          position absolute
          top 0
          left 0
          right 0
          bottom 2px
          background var(--color-bg-control)
          z-index 2
          border-top-right-radius 19px
          border-bottom-right-radius 19px

        .notifyInputProceed
          border-top-right-radius 20px
          border-bottom-right-radius 20px

        .notifyInputSingleButton:before
          content ''
          position absolute
          top 0
          left 0
          right 0
          bottom 2px
          background var(--color-bg-hover)
          z-index 2
          border-radius 19px

        .notifyInputSingleButton
          left 50%
          transform translate(-50%, 0)
          border-radius 20px

.signerRecovery
  width 100%
  max-height 100%
  overflow-y auto
  padding 16px

  .notifyTitle
    margin-bottom 24px !important

  button, input
    font-family 'MainFont'

  button
    min-height 40px
    border 2px solid var(--color-bg-primary)
    border-radius 18px
    padding 0px 18px
    background var(--color-bg-raised)
    color var(--color-text-primary)
    cursor pointer

  button:hover
    background var(--color-bg-control)

  button:disabled
    cursor default
    opacity 0.45

  input
    width 100%
    height 44px
    border 2px solid var(--color-bg-raised)
    border-radius 14px
    outline none
    padding 0px 14px
    background var(--color-bg-primary)
    color var(--color-text-primary)
    text-align center

.signerRecoveryCandidates
  display flex
  gap 6px
  margin-bottom 18px

  button
    flex 1

  button[aria-pressed='true']
    border-color var(--color-action-primary)

.signerRecoveryIdentity
  display flex
  align-items center
  justify-content center
  gap 12px
  font-size 18px

.signerRecoveryIcon
  width 42px
  height 42px
  display flex
  align-items center
  justify-content center
  border-radius 21px
  background var(--color-bg-raised)

.signerRecoveryStatus
  margin 18px 0px
  color var(--color-status-danger)
  font-size 13px
  font-weight 500
  letter-spacing 0.6px
  text-transform uppercase

  &.ready
    color var(--color-action-primary)

.signerRecoveryActions
  display flex
  flex-direction column
  gap 10px

.signerRecoveryButtonRow
  display flex
  gap 6px

  button
    flex 1

.signerRecoveryPinValue
  min-height 24px
  font-size 22px
  letter-spacing 5px

.signerRecoveryPinGrid
  display grid
  grid-template-columns repeat(3, 1fr)
  gap 6px

  button
    padding 0px

.signerRecoveryFooter
  margin-top 24px

  button
    width 100%

.signerRecoveryLoader
  width 42px
  height 42px
  margin 22px auto
  border 3px solid var(--color-bg-raised)
  border-left-color var(--color-action-primary)
  border-radius 50%
  animation signerRecoverySpin 0.6s linear infinite

@keyframes signerRecoverySpin
  to
    transform rotate(360deg)
