{
  "name": "newframe",
  "version": "0.1.0",
  "description": "System-wide web3",
  "main": "compiled/main",
  "scripts": {
    "clean": "rimraf dist dist-preview bundle compiled node_modules",
    "setup": "bun install && bun run rebuild:natives",
    "dev": "bun run compile && bun run bundle && bun ../../harness/newframe/live-harness.ts",
    "trade:local": "bun ./scripts/local-trade-service.ts",
    "harness:newframe": "bun run dev",
    "bundle": "bun run tokens:generate && rimraf bundle && bun build resources/bridge/index.ts --outfile=./bundle/bridge.js --target=browser --format=cjs --external=electron --sourcemap=inline && bun ./scripts/bundle-renderer-bun.ts",
    "tokens:generate": "bun ./scripts/generate-color-tokens.ts",
    "tokens:check": "bun ./scripts/generate-color-tokens.ts --check",
    "colors:check": "bun ./scripts/check-color-literals.ts",
    "architecture:check": "bun ./scripts/check-architecture.ts",
    "sync:assets": "bun ./scripts/sync-assets.ts",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "tsgo --project tsconfig.json --noEmit",
    "knip": "knip",
    "format": "prettier --write '**/*.{yml,json,md,html,ts,tsx,js,mjs}' --config ../../.prettierrc.json --ignore-path ../../.prettierignore",
    "compile": "bun run sync:assets && tsgo --project tsconfig.build.json",
    "compile:watch": "bun run sync:assets && tsgo --project tsconfig.build.json -w",
    "build": "bun run compile && sleep 4 && bun run bundle && sleep 4 && electron-builder --config=build/electron-builder-standard.js",
    "install:preview": "bun run compile && sleep 4 && bun run bundle && sleep 4 && electron-builder --mac --config=build/electron-builder-preview.js && bun ./scripts/install-preview.ts",
    "publish": "bun run sync:assets && electron-builder -c.snap.publish=github --config=build/electron-builder-standard.js",
    "publish:linux:arm64": "bun run sync:assets && electron-builder -c.snap.publish=github --config=build/electron-builder-linux-arm64.js",
    "rebuild:natives": "electron-builder install-app-deps",
    "test": "bun run test:unit && bun run test:e2e",
    "test:unit": "bun run tokens:check && bun run colors:check && bun run architecture:check && bun ./scripts/test-main.ts && bun test --preload ./test/bun.dom.ts --timeout 500 test/app test/resources/Hooks test/resources/Components && bun test --preload ./test/bun.setup.ts --timeout 1000 test/resources/domain test/resources/utils test/scripts",
    "test:e2e": "bun test --preload ./test/bun.setup.ts --timeout 30000 test/e2e",
    "test:usbAdapters": "bun test --preload ./test/bun.setup.ts --timeout 1000 test/main/signers/ledger/adapter.test.ts"
  },
  "author": {
    "name": "NewFrame Labs",
    "email": "My@my.came",
    "url": "https://newframe.sh"
  },
  "license": "GPL-3.0",
  "dependencies": {
    "@donnoh/gns-utils": "^0.2.0",
    "@ethereumjs/common": "^10.1.2",
    "@ethereumjs/rlp": "^10.1.2",
    "@ethereumjs/tx": "^10.1.2",
    "@ethereumjs/util": "^10.1.2",
    "@ledgerhq/hw-app-eth": "^7.8.5",
    "@ledgerhq/hw-transport": "6.35.3",
    "@ledgerhq/hw-transport-node-hid-noevents": "6.35.3",
    "@ledgerhq/hw-transport-node-hid-singleton": "6.35.3",
    "@metamask/eth-sig-util": "^8.2.0",
    "@scure/bip32": "^2.2.0",
    "@trezor/connect": "^9.7.3",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-common": "^3.0.4",
    "@zxcvbn-ts/language-en": "^3.0.2",
    "conf": "^15.1.0",
    "electron-log": "^5.4.4",
    "electron-updater": "6.8.9",
    "ethers": "6.16.0",
    "gridplus-sdk": "^4.0.0",
    "hotkeys-js": "^4.0.4",
    "immer": "^11.1.11",
    "node-hid": "2.1.2",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "semver": "7",
    "styled-components": "^6.4.2",
    "uuid": "^14.0.0",
    "ws": "8.21.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron/notarize": "3.1.1",
    "@happy-dom/global-registrator": "^20.10.5",
    "@ledgerhq/hw-transport-mocker": "6.34.3",
    "@ledgerhq/types-live": "6.56.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/node": "24",
    "@types/node-hid": "1.3.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/semver": "^7.7.1",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "^7.0.0-dev.20260610.1",
    "buffer": "^6.0.3",
    "electron": "42.4.0",
    "electron-builder": "26.15.2",
    "electron-devtools-installer": "4.0.0",
    "events": "^3.3.0",
    "knip": "6.16.1",
    "node-gyp": "^12.3.0",
    "rimraf": "^6.1.3",
    "stylus": "0.63.0",
    "typescript": "6.0.3"
  },
  "alias": {
    "uuid": "./node_modules/uuid/dist/index.js",
    "buffer": "buffer",
    "crypto": false,
    "path": false,
    "process": false,
    "punycode": false,
    "querystring": false,
    "stream": false,
    "string_decoder": false,
    "url": false,
    "http": false,
    "https": false,
    "zlib": false
  },
  "engines": {
    "electron": "42",
    "node": ">= 22.12.0"
  },
  "browserslist": [
    "last 1 Electron major version"
  ],
  "bridge": "./bundle/bridge.js",
  "tray": "./bundle/tray.html",
  "dash": "./bundle/dash.html",
  "dapp": "./bundle/dapp.html",
  "targets": {
    "main": false,
    "dash": {
      "context": "browser"
    },
    "dapp": {
      "context": "browser"
    },
    "tray": {
      "context": "browser"
    },
    "default": {
      "distDir": "./bundle"
    }
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/wardenjakx/newframe.git",
    "directory": "apps/newframe"
  },
  "trustedDependencies": [
    "core-js",
    "electron",
    "keccak",
    "lmdb",
    "node-hid",
    "secp256k1"
  ],
  "overrides": {
    "node-gyp": "12.3.0",
    "@ledgerhq/hw-transport": "6.35.3",
    "@ledgerhq/devices": "8.15.0",
    "@ledgerhq/logs": "6.17.0",
    "usb": "2.18.0"
  }
}
