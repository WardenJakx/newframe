{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM"],
    "types": ["node"],
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "typeRoots": ["./node_modules/@types", "./@types"]
  },
  "include": ["./@types/**/*.d.ts", "./resources/bridge/**/*.ts"]
}
