{
  "name": "newframe-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "harness",
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky",
    "newframe": "bun --cwd apps/newframe",
    "newframe-extension": "bun --cwd apps/newframe-extension",
    "extension": "bun --cwd apps/newframe-extension",
    "build": "bun run newframe build && bun run newframe-extension build",
    "dev:newframe": "bun run newframe dev",
    "harness:newframe": "bun run newframe harness:newframe",
    "build:newframe": "bun run newframe build",
    "build:newframe-extension": "bun run newframe-extension build",
    "test": "bun run test:unit",
    "test:unit": "bun run test:newframe && bun run test:newframe-extension",
    "test:newframe": "bun run newframe test:unit",
    "test:newframe-extension": "bun run newframe-extension test",
    "test:e2e": "bun run newframe test:e2e",
    "test:all": "bun run test:unit && bun run test:e2e",
    "typecheck": "bun run newframe typecheck && bun run newframe-extension typecheck",
    "lint": "eslint . --quiet --cache --cache-location node_modules/.cache/eslint/.eslintcache",
    "lint:warn": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write '**/*.{yml,json,md,html,ts,tsx,js,mjs}'",
    "format:check": "prettier --check '**/*.{yml,json,md,html,ts,tsx,js,mjs}' --cache",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test",
    "dep:report": "bun scripts/dep-report.ts",
    "visual:harness:newframe": "bun exec 'node --experimental-strip-types harness/newframe/visual-harness.ts'"
  },
  "packageManager": "bun@1.3.12",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-testing-library": "7.16.2",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "playwright-core": "^1.61.1",
    "prettier": "^3.8.3",
    "typescript-eslint": "8.61.0"
  },
  "overrides": {
    "node-gyp": "12.3.0",
    "@ledgerhq/hw-transport": "6.35.3",
    "@ledgerhq/devices": "8.15.0",
    "@ledgerhq/logs": "6.17.0",
    "usb": "2.18.0"
  }
}
