    "clean": "bun ./scripts/clean.ts",
    "assets:copy": "bun ./scripts/copy-assets.ts",
    "styles:generate": "panda codegen --clean && panda",
    "styles:watch": "panda --watch",
    "build": "bun run clean && bun run styles:generate && tsc --project tsconfig.json && bun run assets:copy",
    "artifacts:check": "bun ./scripts/check-artifacts.ts",
    "check": "bun run artifacts:check",
    "typecheck": "bun run styles:generate && tsc --project tsconfig.json --noEmit",
    "test": "bun test --preload ./test/setup.ts",
    "watch:types": "tsc --project tsconfig.json --watch --preserveWatchOutput",
    "watch:assets": "bun ./scripts/watch-assets.ts",
    "watch": "bun run styles:generate && bun run assets:copy && bun run --parallel watch:types watch:assets styles:watch"
