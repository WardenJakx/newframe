{
  "name": "@newframe/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./header": {
      "types": "./dist/header/HeaderBar.d.ts",
      "import": "./dist/header/HeaderBar.js",
      "default": "./dist/header/HeaderBar.js"
    },
    "./icon": {
      "types": "./dist/icon/Icon.d.ts",
      "import": "./dist/icon/Icon.js",
      "default": "./dist/icon/Icon.js"
    },
    "./icon-button": {
      "types": "./dist/icon-button/IconButton.d.ts",
      "import": "./dist/icon-button/IconButton.js",
      "default": "./dist/icon-button/IconButton.js"
    },
    "./identity-control": {
      "types": "./dist/identity-control/IdentityControl.d.ts",
      "import": "./dist/identity-control/IdentityControl.js",
      "default": "./dist/identity-control/IdentityControl.js"
    },
    "./menu": {
      "types": "./dist/menu/Menu.d.ts",
      "import": "./dist/menu/Menu.js",
      "default": "./dist/menu/Menu.js"
    },
    "./root": {
      "types": "./dist/root/UIRoot.d.ts",
      "import": "./dist/root/UIRoot.js",
      "default": "./dist/root/UIRoot.js"
    },
    "./settings-panel": {
      "types": "./dist/settings-panel/SettingsPanel.d.ts",
      "import": "./dist/settings-panel/SettingsPanel.js",
      "default": "./dist/settings-panel/SettingsPanel.js"
    },
    "./stack": {
      "types": "./dist/layout/Stack.d.ts",
      "import": "./dist/layout/Stack.js",
      "default": "./dist/layout/Stack.js"
    },
    "./text": {
      "types": "./dist/typography/Text.d.ts",
      "import": "./dist/typography/Text.js",
      "default": "./dist/typography/Text.js"
    },
    "./tokens/colors": {
      "types": "./dist/tokens/colors.d.ts",
      "import": "./dist/tokens/colors.js",
      "default": "./dist/tokens/colors.js"
    }
  },
  "scripts": {
    "clean": "bun ./scripts/clean.ts",
    "tokens:generate": "bun ./scripts/generate-tokens.ts",
    "tokens:check": "bun ./scripts/generate-tokens.ts --check",
    "assets:copy": "bun ./scripts/copy-assets.ts",
    "build": "bun run clean && bun run tokens:generate && tsc --project tsconfig.json && bun run assets:copy",
    "artifacts:check": "bun ./scripts/check-artifacts.ts",
    "check": "bun run tokens:check && bun run artifacts:check",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "bun test --preload ./test/setup.ts",
    "watch:types": "tsc --project tsconfig.json --watch --preserveWatchOutput",
    "watch:assets": "bun ./scripts/watch-assets.ts",
    "watch": "bun run tokens:generate && bun run assets:copy && bun run --parallel watch:types watch:assets"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.5",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "6.0.3"
  }
}
